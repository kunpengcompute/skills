## ⚡ 优先阅读建议

按 "方向匹配 × 强相关密度" 综合排序（仅含本次实际抓取的会议·年）：

{% set fetched_year_entries = [] %}
{% for c in tier_s + tier_a + tier_b %}
{% for y in year_columns %}
{% set yi = c.years[y] %}
{% if yi and yi.status == "fetched" %}
{% set _ = fetched_year_entries.append({"name": c.name, "year": y, "direction_match": c.direction_match,
                                          "total": yi.total, "green": yi.green,
                                          "composite_score": c.composite_score,
                                          "md_link": yi.md_link}) %}
{% endif %}
{% endfor %}
{% endfor %}
{% set ranked = fetched_year_entries|sort(attribute='composite_score', reverse=true)|list %}
{% if ranked %}
