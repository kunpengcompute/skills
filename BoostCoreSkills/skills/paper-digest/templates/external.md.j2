{# Group by source_subtype and relevance #}
{% set ns = namespace(by_source={}) %}
{% for p in papers if p.relevance in ("green", "yellow") %}
{%- set st = p.source_subtype or "arxiv" -%}
{%- if st not in ns.by_source -%}
  {%- set _ = ns.by_source.update({st: {"green": [], "yellow": []}}) -%}
{%- endif -%}
{%- set _ = ns.by_source[st][p.relevance].append(p) -%}
{% endfor %}

{% set source_title = {
    "arxiv": "🌐 arXiv（自动检索 · cs.OS / cs.PL / cs.AR / cs.DC / cs.PF / cs.SE）",
    "labs": "🏛️ 顶级实验室",
    "researchers": "👤 关键人物（Scholar 主页 / 个人博客）",
    "blogs": "📝 博客 / 厂商文章",
    "rfcs": "📡 RFC / 提案"
} %}

{% set source_order = ["arxiv", "labs", "researchers", "rfcs", "blogs"] %}

{% for st in source_order if st in ns.by_source %}
{% set bucket = ns.by_source[st] %}
{% if bucket.green or bucket.yellow %}
