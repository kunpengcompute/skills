+/**************************************************//**
+@file include/ut0cpu_cache.h
+Utilities related to CPU cache.
+
+Backported from MySQL 8.0 WL#10314.
+Adapted for C++03 compatibility.
+
+Created 02/03/2026
+*******************************************************/
+
+#ifndef ut0cpu_cache_h
+#define ut0cpu_cache_h
+
+#include "univ.i"  /* For basic types */
+
+/** CPU cache line size - use the value from ut0counter.h convention */
+#ifndef CACHE_LINE_SIZE
+# ifdef __powerpc__
+#  define CACHE_LINE_SIZE	128
+# else
+#  define CACHE_LINE_SIZE	64
+# endif
+#endif /* CACHE_LINE_SIZE */
+
+namespace ut {
+
+/** CPU cache line size */
+static const ulint INNODB_CACHE_LINE_SIZE = CACHE_LINE_SIZE;
+
+/*********************************************************************//**
+A utility wrapper class, which adds padding at the end of the wrapped
+structure, so that the next object after it is guaranteed to be in the
+next cache line. This is to avoid false-sharing.
+
+Note: In C++03, we cannot use inheriting constructors (using T::T),
+so the wrapped type T must have a default constructor, and initialization
+must be done separately after construction.
+*/
+template <typename T>
+struct Cacheline_padded : public T {
+	/** Padding to ensure next object starts on a new cache line */
+	char	pad[INNODB_CACHE_LINE_SIZE];
+
+	/** Default constructor */
+	Cacheline_padded() : T() {}
+};
+
+}  /* namespace ut */
+
+#endif /* ut0cpu_cache_h */
