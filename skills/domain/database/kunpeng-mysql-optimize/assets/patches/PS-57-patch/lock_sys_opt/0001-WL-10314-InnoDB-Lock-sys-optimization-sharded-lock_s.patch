+/*********************************************************************//**
+Identifies the table shard which contains locks for the given table.
+@param[in]	table_id	The id of the table
+@return Integer in the range [0..SHARDS_COUNT) */
+size_t
+Latches::Table_shards::get_shard(
+	table_id_t	table_id)
+{
+	return(static_cast<size_t>(table_id % SHARDS_COUNT));
+}
