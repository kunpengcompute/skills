+/* ================================================================
+   Global_exclusive_latch_guard implementation
+   ================================================================ */
+
+/*********************************************************************//**
+Constructor - acquires exclusive global latch.
+@param[in]	location	Source location where guard is created */
+Global_exclusive_latch_guard::Global_exclusive_latch_guard(
+	const ut::Location&	location)
+{
+	lock_sys->latches.m_global_latch.x_lock(location.filename, location.line);
+}
+
+/*********************************************************************//**
+Destructor - releases exclusive global latch. */
+Global_exclusive_latch_guard::~Global_exclusive_latch_guard()
+{
+	lock_sys->latches.m_global_latch.x_unlock();
+}
+
+/* ================================================================
+   Global_exclusive_try_latch implementation
+   ================================================================ */
+
+/*********************************************************************//**
+Constructor - tries to acquire exclusive global latch.
+@param[in]	location	Source location where guard is created */
+Global_exclusive_try_latch::Global_exclusive_try_latch(
+	const ut::Location&	location)
+{
+	m_owns_exclusive_global_latch =
+		lock_sys->latches.m_global_latch.try_x_lock(
+			location.filename, location.line);
+}
+
+/*********************************************************************//**
+Destructor - releases exclusive global latch if it was acquired. */
+Global_exclusive_try_latch::~Global_exclusive_try_latch()
+{
+	if (m_owns_exclusive_global_latch) {
+		lock_sys->latches.m_global_latch.x_unlock();
+	}
+}
+
+/* ================================================================
+   Global_shared_latch_guard implementation
+   ================================================================ */
+
+/*********************************************************************//**
+Constructor - acquires shared global latch.
+@param[in]	location	Source location where guard is created */
