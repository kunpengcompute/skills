+	const ut::Location&	location MY_ATTRIBUTE((unused)),
+	table_id_t		table_id)
+	:
+	m_shard_mutex(lock_sys->latches.m_table_shards.get_mutex(table_id))
+{
+	ut_ad(locksys::owns_shared_global_latch()
+	      || locksys::owns_exclusive_global_latch());
+	mutex_enter(&m_shard_mutex);
+}
+
+/*********************************************************************//**
+Constructor - acquires shard latch for page.
+@param[in]	location	Source location where guard is created
+@param[in]	page_id		Page identifier */
+Shard_naked_latch_guard::Shard_naked_latch_guard(
+	const ut::Location&	location MY_ATTRIBUTE((unused)),
+	const page_id_t&	page_id)
+	:
+	m_shard_mutex(lock_sys->latches.m_page_shards.get_mutex(page_id))
+{
+	ut_ad(locksys::owns_shared_global_latch()
+	      || locksys::owns_exclusive_global_latch());
+	mutex_enter(&m_shard_mutex);
+}
+
+/*********************************************************************//**
+Destructor - releases shard latch. */
+Shard_naked_latch_guard::~Shard_naked_latch_guard()
+{
+	mutex_exit(&m_shard_mutex);
+}
+
+/* ================================================================
+   Shard_naked_latches_guard implementation
+   ================================================================ */
+
+/*********************************************************************//**
+Returns the mutex with smaller address (for consistent ordering).
+@param[in]	mutex_a		First mutex
+@param[in]	mutex_b		Second mutex
+@return Reference to mutex with smaller address */
+inline
+Lock_mutex&
+get_mutex_with_smaller_addr(
+	Lock_mutex&	mutex_a,
+	Lock_mutex&	mutex_b)
+{
+	return((&mutex_a < &mutex_b) ? mutex_a : mutex_b);
+}
+
+/*********************************************************************//**
+Returns the mutex with larger address (for consistent ordering).
+@param[in]	mutex_a		First mutex
+@param[in]	mutex_b		Second mutex
+@return Reference to mutex with larger address */
+inline
+Lock_mutex&
+get_mutex_with_larger_addr(
+	Lock_mutex&	mutex_a,
+	Lock_mutex&	mutex_b)
+{
+	return((&mutex_a < &mutex_b) ? mutex_b : mutex_a);
+}
+
+/*********************************************************************//**
+Internal constructor - acquires given mutexes in correct order.
+@param[in]	shard_mutex_a	First mutex
+@param[in]	shard_mutex_b	Second mutex */
+Shard_naked_latches_guard::Shard_naked_latches_guard(
+	Lock_mutex&	shard_mutex_a,
+	Lock_mutex&	shard_mutex_b)
+	:
+	/* Order by address to prevent deadlocks */
+	m_shard_mutex_1(get_mutex_with_smaller_addr(shard_mutex_a, shard_mutex_b)),
+	m_shard_mutex_2(get_mutex_with_larger_addr(shard_mutex_a, shard_mutex_b))
+{
+	ut_ad(locksys::owns_shared_global_latch()
+	      || locksys::owns_exclusive_global_latch());
+
+	mutex_enter(&m_shard_mutex_1);
+
+	/* Only lock second mutex if different from first */
+	if (&m_shard_mutex_1 != &m_shard_mutex_2) {
+		mutex_enter(&m_shard_mutex_2);
+	}
+}
+
+/*********************************************************************//**
+Constructor - acquires shard latches for two blocks.
+@param[in]	block_a		First block
+@param[in]	block_b		Second block */
+Shard_naked_latches_guard::Shard_naked_latches_guard(
+	const buf_block_t&	block_a,
+	const buf_block_t&	block_b)
+	:
+	/* Get mutexes for both blocks and order by address */
+	m_shard_mutex_1(get_mutex_with_smaller_addr(
+		lock_sys->latches.m_page_shards.get_mutex(block_a.page.id),
+		lock_sys->latches.m_page_shards.get_mutex(block_b.page.id))),
+	m_shard_mutex_2(get_mutex_with_larger_addr(
+		lock_sys->latches.m_page_shards.get_mutex(block_a.page.id),
+		lock_sys->latches.m_page_shards.get_mutex(block_b.page.id)))
+{
+	ut_ad(locksys::owns_shared_global_latch()
+	      || locksys::owns_exclusive_global_latch());
+
+	mutex_enter(&m_shard_mutex_1);
+
+	/* Only lock second mutex if different from first */
+	if (&m_shard_mutex_1 != &m_shard_mutex_2) {
+		mutex_enter(&m_shard_mutex_2);
+	}
+}
+
+/*********************************************************************//**
+Destructor - releases shard latches. */
+Shard_naked_latches_guard::~Shard_naked_latches_guard()
+{
+	/* Unlock in reverse order */
+	if (&m_shard_mutex_1 != &m_shard_mutex_2) {
+		mutex_exit(&m_shard_mutex_2);
+	}
+	mutex_exit(&m_shard_mutex_1);
+}
+
+/* ================================================================
+   Unsafe_global_latch_manipulator implementation
+   ================================================================ */
+
+/*********************************************************************//**
+Releases the global exclusive latch.
+Must only be called when holding the exclusive latch. */
+void
+Unsafe_global_latch_manipulator::exclusive_unlatch()
+{
+	lock_sys->latches.m_global_latch.x_unlock();
+}
+
+/*********************************************************************//**
+Acquires the global exclusive latch.
+@param[in]	location	Source location where latch is acquired */
+void
+Unsafe_global_latch_manipulator::exclusive_latch(
+	const ut::Location&	location)
+{
+	lock_sys->latches.m_global_latch.x_lock(location.filename, location.line);
+}
+
+}  /* namespace locksys */
