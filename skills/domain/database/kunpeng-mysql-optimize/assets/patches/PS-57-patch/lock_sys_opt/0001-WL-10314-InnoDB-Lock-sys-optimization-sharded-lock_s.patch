+	const ut::Location&	location)
+{
+	lock_sys->latches.m_global_latch.s_lock(location.filename, location.line);
+}
+
+/*********************************************************************//**
+Destructor - releases shared global latch. */
+Global_shared_latch_guard::~Global_shared_latch_guard()
+{
+	lock_sys->latches.m_global_latch.s_unlock();
+}
+
+/* ================================================================
+   Shard_naked_latch_guard implementation
+   ================================================================ */
+
+/*********************************************************************//**
+Internal constructor - acquires given mutex.
+@param[in]	location	Source location where guard is created
+@param[in]	shard_mutex	The mutex to acquire */
+Shard_naked_latch_guard::Shard_naked_latch_guard(
+	const ut::Location&	location MY_ATTRIBUTE((unused)),
+	Lock_mutex&		shard_mutex)
+	:
+	m_shard_mutex(shard_mutex)
+{
