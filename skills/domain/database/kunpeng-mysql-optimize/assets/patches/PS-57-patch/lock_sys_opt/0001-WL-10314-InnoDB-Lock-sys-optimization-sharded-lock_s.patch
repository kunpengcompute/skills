+/**************************************************//**
+@file include/sync0sharded_rw.h
+The sharded read-write lock (for threads).
+
+The s-lock scales better than in single rw-lock,
+but the x-lock is much slower.
+
+Backported from MySQL 8.0 WL#10314.
+Adapted for C++03 compatibility.
+
+Created 02/03/2026
+*******************************************************/
+
+#ifndef sync0sharded_rw_h
+#define sync0sharded_rw_h
+
+#include "sync0rw.h"
+#include "ut0cpu_cache.h"
+#include "ut0counter.h"
+#include "ut0ut.h"
+#include "ut0new.h"
+
+#ifndef UNIV_HOTBACKUP
+
+/*********************************************************************//**
+Rw-lock with very fast, highly concurrent s-lock but slower x-lock.
+It's basically array of rw-locks. When s-lock is being acquired, single
+rw-lock from array is selected randomly and s-locked. Therefore, all
+rw-locks from array has to be x-locked when x-lock is being acquired.
+
+Purpose of this data structure is to reduce contention on single atomic
+in single rw-lock when a lot of threads need to acquire s-lock very often,
+but x-lock is very rare.
+
+C++03 compatible version.
+*/
+class Sharded_rw_lock {
+public:
+	/** Default constructor */
+	Sharded_rw_lock()
+		:
+		m_shards(NULL),
+		m_n_shards(0)
+	{
+	}
+
+	/*********************************************************************//**
+	Creates the sharded rw-lock with given number of shards.
+	@param[in]	pfs_key		PFS key for the rw-locks (if UNIV_PFS_RWLOCK)
+	@param[in]	level		Latch level for the rw-locks
+	@param[in]	n_shards	Number of shards (must be power of 2)
+	*/
+	void
+	create(
+#ifdef UNIV_PFS_RWLOCK
+		mysql_pfs_key_t	pfs_key,
+#endif /* UNIV_PFS_RWLOCK */
+		latch_level_t	level,
+		size_t		n_shards)
+	{
+		ut_ad(ut_is_2pow(n_shards));
+		m_n_shards = n_shards;
+
+		/* Allocate memory for shards using InnoDB memory allocation */
+		m_shards = static_cast<Shard*>(
+			ut_zalloc_nokey(sizeof(Shard) * n_shards));
+
+		for (size_t i = 0; i < n_shards; ++i) {
+#ifdef UNIV_PFS_RWLOCK
+			rw_lock_create(pfs_key, &m_shards[i].lock, level);
+#else
+			rw_lock_create(PFS_NOT_INSTRUMENTED,
+				       &m_shards[i].lock, level);
+#endif /* UNIV_PFS_RWLOCK */
+		}
+	}
+
+	/*********************************************************************//**
+	Destroys the sharded rw-lock and frees memory.
+	*/
+	void
+	free()
+	{
+		ut_a(m_shards != NULL);
+
+		for (size_t i = 0; i < m_n_shards; ++i) {
+			rw_lock_free(&m_shards[i].lock);
+		}
+
+		ut_free(m_shards);
+		m_shards = NULL;
+		m_n_shards = 0;
+	}
+
+	/*********************************************************************//**
+	Acquires shared lock on a random shard.
+	@param[in]	file	File name where lock is acquired
+	@param[in]	line	Line number where lock is acquired
+	@return		Shard number that was locked (needed for unlock)
+	*/
+	size_t
+	s_lock(
+		const char*	file,
+		ulint		line)
+	{
+		const size_t shard_no = get_random_shard();
+		rw_lock_s_lock_inline(&m_shards[shard_no].lock, 0, file, line);
+		return(shard_no);
+	}
+
+	/*********************************************************************//**
+	Releases shared lock on the specified shard.
+	@param[in]	shard_no	Shard number returned from s_lock()
+	*/
+	void
+	s_unlock(
+		size_t	shard_no)
+	{
+		ut_a(shard_no < m_n_shards);
+		rw_lock_s_unlock(&m_shards[shard_no].lock);
+	}
+
+	/*********************************************************************//**
+	Tries to obtain exclusive latch - similar to x_lock(), but non-blocking,
+	and thus can fail.
+	@param[in]	file	File name where lock is acquired
+	@param[in]	line	Line number where lock is acquired
+	@return	true iff succeeded to acquire the exclusive latch
+	*/
+	bool
+	try_x_lock(
+		const char*	file,
+		ulint		line)
+	{
+		for (size_t shard_no = 0; shard_no < m_n_shards; ++shard_no) {
+			if (!rw_lock_x_lock_func_nowait_inline(
+				&m_shards[shard_no].lock, file, line)) {
+				/* Failed to acquire lock on this shard,
+				release all previously acquired locks */
+				while (shard_no > 0) {
+					--shard_no;
+					rw_lock_x_unlock(&m_shards[shard_no].lock);
+				}
+				return(false);
+			}
+		}
+		return(true);
+	}
+
+	/*********************************************************************//**
+	Acquires exclusive lock on all shards.
+	@param[in]	file	File name where lock is acquired
+	@param[in]	line	Line number where lock is acquired
+	*/
+	void
+	x_lock(
+		const char*	file,
+		ulint		line)
+	{
+		for (size_t i = 0; i < m_n_shards; ++i) {
+			rw_lock_x_lock_inline(&m_shards[i].lock, 0, file, line);
+		}
+	}
+
+	/*********************************************************************//**
+	Releases exclusive lock on all shards.
+	*/
+	void
+	x_unlock()
+	{
+		for (size_t i = 0; i < m_n_shards; ++i) {
+			rw_lock_x_unlock(&m_shards[i].lock);
+		}
+	}
+
+#ifdef UNIV_DEBUG
+	/*********************************************************************//**
+	Checks if the current thread owns shared lock on the given shard.
+	@param[in]	shard_no	Shard number to check
+	@return	true iff current thread owns s-latch on the shard
+	*/
+	bool
+	s_own(
+		size_t	shard_no) const
+	{
+		return(rw_lock_own(&m_shards[shard_no].lock, RW_LOCK_S));
+	}
+
+	/*********************************************************************//**
+	Checks if the current thread owns exclusive lock.
+	@return	true iff current thread owns x-latch (checks first shard only)
+	*/
+	bool
+	x_own() const
+	{
+		return(rw_lock_own(&m_shards[0].lock, RW_LOCK_X));
+	}
+#endif /* UNIV_DEBUG */
+
+private:
+	/** Structure to hold a single rw-lock with cache line padding */
+	struct Shard {
+		rw_lock_t	lock;
+		char		pad[CACHE_LINE_SIZE];
+
+		/** Default constructor */
+		Shard()
+		{
+			memset(pad, 0, sizeof(pad));
+		}
+	};
+
+	/** Get a random shard index
+	@return		Random index in range [0, m_n_shards - 1]
+	*/
+	size_t
+	get_random_shard() const
+	{
+		return(default_indexer_t<>::get_rnd_index() & (m_n_shards - 1));
+	}
+
+	/** Array of shards, each containing a rw-lock */
+	Shard*	m_shards;
+
+	/** Number of shards */
+	size_t	m_n_shards;
+};
+
+#endif /* !UNIV_HOTBACKUP */
+
+#endif /* sync0sharded_rw_h */
