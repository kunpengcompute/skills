+/* Static member initialization for thread-local shard ID.
+   Initialized to NOT_IN_USE to indicate no shard is held. */
+UNIV_THREAD_LOCAL size_t Latches::Unique_sharded_rw_lock::s_shard_id =
+	Latches::Unique_sharded_rw_lock::NOT_IN_USE;
+
+/*********************************************************************//**
+Constructor for Unique_sharded_rw_lock */
+Latches::Unique_sharded_rw_lock::Unique_sharded_rw_lock()
+{
