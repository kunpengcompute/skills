+/* ================================================================
+   Page_shards implementation
+   ================================================================ */
+
+/*********************************************************************//**
+Constructor for Page_shards */
+Latches::Page_shards::Page_shards()
+{
+	for (size_t i = 0; i < SHARDS_COUNT; ++i) {
+		mutex_create(LATCH_ID_LOCK_SYS_PAGE, &m_mutexes[i]);
+	}
+}
+
+/*********************************************************************//**
+Destructor for Page_shards */
+Latches::Page_shards::~Page_shards()
+{
+	for (size_t i = 0; i < SHARDS_COUNT; ++i) {
+		mutex_free(&m_mutexes[i]);
+	}
+}
+
+/*********************************************************************//**
+Identifies the page shard which contains record locks for records from
+the given page.
+@param[in]	page_id		Page identifier
+@return Integer in the range [0..SHARDS_COUNT) */
+size_t
+Latches::Page_shards::get_shard(
+	const page_id_t&	page_id)
+{
+	/* We always use lock_sys->rec_hash regardless of the exact type of
+	the lock. It may happen that the lock is a predicate lock, in which
+	case, it would make more sense to use hash_calc_cell_id with proper
+	hash table size. The current implementation works, because the size
+	of all three hashmaps is always the same. */
+	ut_ad(lock_sys->rec_hash->n_cells == lock_sys->prdt_hash->n_cells);
+	ut_ad(lock_sys->rec_hash->n_cells == lock_sys->prdt_page_hash->n_cells);
+
+	/* We need a property that if two pages are mapped to the same bucket
+	of the hash table, and thus their lock queues are merged, then these
+	two lock queues are protected by the same shard. This is why to compute
+	the shard we use the cell_id as the input and not the original
+	lock_rec_fold's result. */
+	const ulint fold = lock_rec_fold(
+		static_cast<ulint>(page_id.space()),
+		static_cast<ulint>(page_id.page_no()));
+	const ulint cell_id = hash_calc_hash(fold, lock_sys->rec_hash);
+
+	return(static_cast<size_t>(cell_id % SHARDS_COUNT));
+}
+
+/*********************************************************************//**
+Returns the mutex which protects the page shard.
+@param[in]	page_id		Page identifier
+@return The mutex responsible for the shard containing the page */
+Lock_mutex&
+Latches::Page_shards::get_mutex(
+	const page_id_t&	page_id)
+{
+	return(m_mutexes[get_shard(page_id)]);
+}
+
+/*********************************************************************//**
+Returns the mutex which protects the page shard. (const version)
+@param[in]	page_id		Page identifier
+@return The mutex responsible for the shard containing the page */
+const Lock_mutex&
+Latches::Page_shards::get_mutex(
+	const page_id_t&	page_id) const
+{
+	return(m_mutexes[get_shard(page_id)]);
+}
+
+/* ================================================================
+   Table_shards implementation
+   ================================================================ */
+
+/*********************************************************************//**
+Constructor for Table_shards */
