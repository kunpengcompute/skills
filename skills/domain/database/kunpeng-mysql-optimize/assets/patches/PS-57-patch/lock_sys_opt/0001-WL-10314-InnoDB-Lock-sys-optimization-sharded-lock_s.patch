+/**************************************************//**
+@file include/ut0class_life_cycle.h
+Utilities related to class lifecycle.
+
+Backported from MySQL 8.0 WL#10314.
+Adapted for C++03 compatibility.
+
+Created 02/03/2026
+*******************************************************/
+
+#ifndef ut0class_life_cycle_h
+#define ut0class_life_cycle_h
+
+namespace ut {
+
+/*********************************************************************//**
+A utility class which, if inherited from, prevents the descendant class
+from being copied, moved, or assigned.
+This is useful for guard classes.
+
+C++03 version: Uses private declaration without implementation.
+*/
+class Non_copyable {
+protected:
+	/** Default constructor */
+	Non_copyable() {}
+
+	/** Destructor - protected and non-virtual */
+	~Non_copyable() {}
+
+private:
+	/** Copy constructor - declared private and not implemented */
+	Non_copyable(const Non_copyable&);
+
+	/** Assignment operator - declared private and not implemented */
+	Non_copyable& operator=(const Non_copyable&);
+};
+
+}  /* namespace ut */
+
+#endif /* ut0class_life_cycle_h */
