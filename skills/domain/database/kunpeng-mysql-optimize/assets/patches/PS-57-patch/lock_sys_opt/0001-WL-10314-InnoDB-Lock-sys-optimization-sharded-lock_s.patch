+51 Franklin Street, Suite 500, Boston, MA 02110-1335 USA
+
+*****************************************************************************/
+
+/**************************************************//**
+@file include/lock0latches.h
+Lock system latches.
+
+The class which handles the logic of latching of lock_sys queues themselves.
+Backported from MySQL 8.0 WL#10314.
+Adapted for C++03 compatibility.
+
+Created 02/03/2026
+*******************************************************/
+
+#ifndef lock0latches_h
+#define lock0latches_h
+
+#include "univ.i"
+#include "sync0sharded_rw.h"
+#include "ut0cpu_cache.h"
+#include "ut0mutex.h"
+#include "ut0rnd.h"
+#include "buf0buf.h"  /* For page_id_t */
+
+/* Forward declarations */
+struct dict_table_t;
+struct buf_block_t;
+
+/** Table ID type */
+#ifndef table_id_t
+typedef ib_id_t	table_id_t;
+#endif
+
+namespace locksys {
+
+/** Lock mutex type - same as used in lock_sys_t */
+typedef ib_mutex_t Lock_mutex;
+
+/*********************************************************************//**
+The class which handles the logic of latching of lock_sys queues themselves.
+The lock requests for table locks and record locks are stored in queues, and to
+allow concurrent operations on these queues, we need a mechanism to latch these
+queues in safe and quick fashion.
+In the past we had a single latch which protected access to all of them.
+Now, we use more granular approach.
+In extreme, one could imagine protecting each queue with a separate latch.
+To avoid having too many latch objects, and having to create and remove them on
+demand, we use a more conservative approach.
+The queues are grouped into a fixed number of shards, and each shard is
+protected by its own mutex.
+
+However, there are several rare events in which we need to "stop the world" -
+latch all queues, to prevent any activity inside lock-sys.
+One way to accomplish this would be to simply latch all the shards one by one,
+but it turns out to be way too slow in debug runs, where such "stop the world"
+events are very frequent due to lock_sys validation.
+
+To allow for efficient latching of everything, we've introduced a global_latch,
+which is a read-write latch.
+Most of the time, we operate on one or two shards, in which case it is
+sufficient to s-latch the global_latch and then latch shard's mutex.
+For the "stop the world" operations, we x-latch the global_latch, which prevents
+any other thread from latching any shard.
+
+This is how this conceptually looks like:
+  [                           global latch                                ]
+                                  |
+                                  v
+  [table shard 1] ... [table shard 512] [page shard 1] ... [page shard 512]
+*/
+class Latches {
+public:
+	/** Number of page shards, and also number of table shards.
+	Must be a power of 2 */
+	static const size_t SHARDS_COUNT = 512;
+
+private:
+	/** Lock mutex with cache line padding */
+	typedef ut::Cacheline_padded<Lock_mutex> Padded_mutex;
+
+	/*********************************************************************//**
+	A helper wrapper around Sharded_rw_lock which simplifies:
+	- lifecycle by providing constructor and destructor, and
+	- s-latching and s-unlatching by keeping track of the shard id used for
+	  spreading the contention.
+	*/
+	class Unique_sharded_rw_lock {
+	public:
+		/** Constructor */
+		Unique_sharded_rw_lock();
+
+		/** Destructor */
+		~Unique_sharded_rw_lock();
+
+		/** Try to acquire exclusive latch (non-blocking)
+		@param[in]	file	File name
+		@param[in]	line	Line number
+		@return true if acquired successfully */
+		bool
+		try_x_lock(
+			const char*	file,
+			ulint		line)
+		{
+			return(m_rw_lock.try_x_lock(file, line));
+		}
+
+		/** Acquire exclusive latch
+		@param[in]	file	File name
+		@param[in]	line	Line number */
+		void
+		x_lock(
+			const char*	file,
+			ulint		line)
+		{
+			ut_ad(s_shard_id == NOT_IN_USE);
+			m_rw_lock.x_lock(file, line);
+		}
+
+		/** Release exclusive latch */
+		void
+		x_unlock()
+		{
+			m_rw_lock.x_unlock();
+		}
+
+		/** Acquire shared latch
+		@param[in]	file	File name
+		@param[in]	line	Line number */
+		void
+		s_lock(
+			const char*	file,
+			ulint		line)
+		{
+			ut_ad(s_shard_id == NOT_IN_USE);
+			s_shard_id = m_rw_lock.s_lock(file, line);
+		}
+
+		/** Release shared latch */
+		void
+		s_unlock()
+		{
+			ut_ad(s_shard_id != NOT_IN_USE);
+			m_rw_lock.s_unlock(s_shard_id);
+			s_shard_id = NOT_IN_USE;
+		}
+
+#ifdef UNIV_DEBUG
+		/** Check if current thread owns x-latch
+		@return true if owns x-latch */
+		bool
+		x_own() const
+		{
+			return(m_rw_lock.x_own());
+		}
+
+		/** Check if current thread owns s-latch
+		@return true if owns s-latch */
+		bool
+		s_own() const
+		{
+			return(s_shard_id != NOT_IN_USE && m_rw_lock.s_own(s_shard_id));
+		}
+#endif /* UNIV_DEBUG */
+
+	private:
+		/** The actual rw_lock implementation */
+		Sharded_rw_lock		m_rw_lock;
+
+		/** The value used to indicate thread did not s-latch any shard */
+		static const size_t	NOT_IN_USE = ~((size_t)0);
+
+		/** Thread-local storage for shard ID.
+		Uses UNIV_THREAD_LOCAL which maps to __thread on Linux. */
+		static UNIV_THREAD_LOCAL size_t	s_shard_id;
+	};
+
+	/*********************************************************************//**
+	Functions related to sharding by page (containing records to lock).
+	This must be done in such a way that two pages which share a single lock
+	queue fall into the same shard. We accomplish this by reusing hash function
+	used to determine lock queue, and then group multiple queues into single
+	shard.
+	*/
+	class Page_shards {
+	public:
+		/** Constructor */
+		Page_shards();
+
+		/** Destructor */
+		~Page_shards();
+
+		/** Returns the mutex which protects the page shard.
+		@param[in]	page_id		Page identifier
+		@return The mutex responsible for the shard containing the page */
+		Lock_mutex&
+		get_mutex(
+			const page_id_t&	page_id);
+
+		/** Returns the mutex which protects the page shard.
+		(const version)
+		@param[in]	page_id		Page identifier
+		@return The mutex responsible for the shard containing the page */
+		const Lock_mutex&
+		get_mutex(
+			const page_id_t&	page_id) const;
+
+	private:
+		/** Identifies the page shard which contains record locks for
+		records from the given page.
+		@param[in]	page_id		Page identifier
+		@return Integer in the range [0..SHARDS_COUNT) */
+		static size_t
+		get_shard(
+			const page_id_t&	page_id);
+
+		/** Each shard is protected by a separate mutex */
+		Padded_mutex	m_mutexes[SHARDS_COUNT];
+	};
+
+	/*********************************************************************//**
+	Functions related to sharding by table.
+	We identify tables by their id. Each table has its own lock queue, so we
+	simply group several such queues into single shard.
+	*/
+	class Table_shards {
+	public:
+		/** Constructor */
+		Table_shards();
+
+		/** Destructor */
+		~Table_shards();
+
+		/** Returns the mutex which protects the table shard.
+		@param[in]	table_id	The id of the table
+		@return The mutex responsible for the shard containing the table */
+		Lock_mutex&
+		get_mutex(
+			table_id_t	table_id);
+
+		/** Returns the mutex which protects the table shard.
+		@param[in]	table		The table
+		@return The mutex responsible for the shard containing the table */
+		Lock_mutex&
+		get_mutex(
+			const dict_table_t&	table);
+
+		/** Returns the mutex which protects the table shard.
+		(const version)
+		@param[in]	table_id	The id of the table
+		@return The mutex responsible for the shard containing the table */
+		const Lock_mutex&
+		get_mutex(
+			table_id_t	table_id) const;
+
+		/** Returns the mutex which protects the table shard.
+		(const version)
+		@param[in]	table		The table
+		@return The mutex responsible for the shard containing the table */
+		const Lock_mutex&
+		get_mutex(
+			const dict_table_t&	table) const;
+
+	private:
+		/** Identifies the table shard which contains locks for
+		the given table.
+		@param[in]	table_id	The id of the table
+		@return Integer in the range [0..SHARDS_COUNT) */
+		static size_t
+		get_shard(
+			table_id_t	table_id);
+
+		/** Each shard is protected by a separate mutex */
+		Padded_mutex	m_mutexes[SHARDS_COUNT];
+	};
+
+	/** Padding to prevent other memory update hotspots from residing
+	on the same memory cache line */
+	char			m_pad1[CACHE_LINE_SIZE];
+
+	/** Global sharded rw-lock */
+	Unique_sharded_rw_lock	m_global_latch;
+
+	/** Page shards for record locks */
+	Page_shards		m_page_shards;
+
+	/** Table shards for table locks */
+	Table_shards		m_table_shards;
+
+public:
+	/** Default constructor */
+	Latches() {}
+
+	/** Destructor */
+	~Latches() {}
+
+	/* You should use following RAII guards to modify the state of Latches */
+	friend class Global_exclusive_latch_guard;
+	friend class Global_exclusive_try_latch;
+	friend class Global_shared_latch_guard;
+	friend class Shard_naked_latch_guard;
+	friend class Shard_naked_latches_guard;
+
+	/** You should not use this functionality in new code.
+	Instead use Global_exclusive_latch_guard.
+	This is intended only to be used within lock0* module, thus this class
+	is only accessible through lock0guards.h.
+	It is only used by lock_rec_fetch_page() as a workaround. */
+	friend class Unsafe_global_latch_manipulator;
+
+#ifdef UNIV_DEBUG
+	/*********************************************************************//**
+	Tests if lock_sys latch is exclusively owned by the current thread.
+	@return true iff the current thread owns exclusive global lock_sys latch */
+	bool
+	owns_exclusive_global_latch() const
+	{
+		return(m_global_latch.x_own());
+	}
+
+	/*********************************************************************//**
+	Tests if lock_sys latch is owned in shared mode by the current thread.
+	@return true iff the current thread owns shared global lock_sys latch */
+	bool
+	owns_shared_global_latch() const
+	{
+		return(m_global_latch.s_own());
+	}
+
+	/*********************************************************************//**
+	Tests if given page shard can be safely accessed by the current thread.
+	@param[in]	page_id		Page identifier
+	@return true iff the current thread owns exclusive global lock_sys latch
+	or both a shared global lock_sys latch and mutex protecting the page shard */
+	bool
+	owns_page_shard(
+		const page_id_t&	page_id) const
+	{
+		return(owns_exclusive_global_latch()
+			|| (m_page_shards.get_mutex(page_id).is_owned()
+			    && owns_shared_global_latch()));
+	}
+
+	/*********************************************************************//**
+	Tests if given table shard can be safely accessed by the current thread.
+	@param[in]	table	the table
+	@return true iff the current thread owns exclusive global lock_sys latch
+	or both a shared global lock_sys latch and mutex protecting the table shard */
+	bool
+	owns_table_shard(
+		const dict_table_t&	table) const
+	{
+		return(owns_exclusive_global_latch()
+			|| (m_table_shards.get_mutex(table).is_owned()
+			    && owns_shared_global_latch()));
+	}
+#endif /* UNIV_DEBUG */
+
+private:
+	/** Disable copy constructor */
+	Latches(const Latches&);
+
+	/** Disable assignment operator */
+	Latches& operator=(const Latches&);
+};
+
+#ifdef UNIV_DEBUG
+/*********************************************************************//**
+Global convenience function to check if the current thread owns the
+table shard latch.
+@return true iff owns table shard latch */
+bool
+owns_table_shard(
+/*=============*/
+	const dict_table_t&	table);		/*!< in: the table */
+
+/*********************************************************************//**
+Global convenience function to check if the current thread owns the
+page shard latch.
+@return true iff owns page shard latch */
+bool
+owns_page_shard(
+/*============*/
+	const page_id_t&	page_id);	/*!< in: page identifier */
+
+/*********************************************************************//**
+Global convenience function to check if the current thread owns the
+exclusive global latch.
+@return true iff owns exclusive global latch */
+bool
+owns_exclusive_global_latch();
+/*=========================*/
+
+/*********************************************************************//**
+Global convenience function to check if the current thread owns the
+shared global latch.
+@return true iff owns shared global latch */
+bool
+owns_shared_global_latch();
+/*======================*/
+#endif /* UNIV_DEBUG */
+
+}  /* namespace locksys */
+
+#endif /* lock0latches_h */
