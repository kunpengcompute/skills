+/** Given a waiting lock and the lock that blocks it, update wait-for edge.
+@param[in] waiting_lock	waiting lock request
+@param[in] blocking_lock	lock which still blocks waiting_lock */
+static
+void
+lock_update_wait_for_edge(
+/*======================*/
+	const lock_t*	waiting_lock,
+	const lock_t*	blocking_lock)
+{
+	ut_ad(locksys::owns_lock_shard(waiting_lock));
+	ut_ad(locksys::owns_lock_shard(blocking_lock));
+	ut_ad(lock_get_wait(waiting_lock));
+	ut_ad(lock_has_to_wait(waiting_lock, blocking_lock));
+
+	/* Still waits, but the blocker might have changed. */
+	if (os_atomic_loadptr(waiting_lock->trx->lock.blocking_trx)
+		!= blocking_lock->trx) {
+		os_atomic_storeptr(waiting_lock->trx->lock.blocking_trx,
+			const_cast<trx_t*>(blocking_lock->trx));
+		lock_wait_request_check_for_cycles();
+	}
+}
+
+/** Given a waiting record lock, grant it if possible, otherwise keep the
+wait-for edge up to date.
+@param[in,out] lock	waiting record lock */
+static
+void
+lock_rec_grant_or_update_wait_for_edge(
+/*===================================*/
+	lock_t*	lock)
+{
+	ut_ad(locksys::owns_lock_shard(lock));
+	ut_ad(lock_get_wait(lock));
+	ut_ad(lock_get_type_low(lock) == LOCK_REC);
+
+	const lock_t*	blocking_lock = lock_rec_has_to_wait_in_queue(lock);
+
+	if (blocking_lock == NULL) {
+		lock_grant(lock);
+	} else {
+		ut_ad(lock->trx != blocking_lock->trx);
+		lock_update_wait_for_edge(lock, blocking_lock);
+	}
+}
+
+/** If lock was waiting for releasing_trx, either grant lock or update edge.
+@param[in,out] lock		waiting/granted record lock
+@param[in] releasing_trx	transaction that has just released a lock */
+static
+void
+lock_rec_grant_or_update_wait_for_edge_if_waiting(
+/*===============================================*/
+	lock_t*		lock,
+	const trx_t*	releasing_trx)
+{
+	if (lock_get_wait(lock)
+	    && os_atomic_loadptr(lock->trx->lock.blocking_trx) == releasing_trx) {
+		ut_ad(lock->trx != releasing_trx);
+		lock_rec_grant_or_update_wait_for_edge(lock);
+	}
+}
