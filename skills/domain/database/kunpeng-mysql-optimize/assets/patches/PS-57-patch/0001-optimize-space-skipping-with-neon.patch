+{
+  my_wc_t wc;
+  int res;
+  const uchar *e = skip_trailing_space(s, slen);
+  const MY_UNICASE_INFO *uni_plane= cs->caseinfo;
+  uint64 tmp1 = *n1;
+  uint64 tmp2 = *n2;
+
