+static size_t
+my_well_formed_len_utf8(const CHARSET_INFO *cs, const char *b, const char *e,
+                        size_t pos, int *error)
+{
+  const char *b_start = b;
+  size_t len = e - b;
+  *error = 0;
+
+  {
+    uint8x16_t vec_b;
+    while (pos >= NEON_VECTOR_LENGTH && len >= NEON_VECTOR_LENGTH)
+    {
+      if (!my_simd_load_ascii_vector((const uchar *)b, &vec_b))
+      {
+        break;
+      }
+
+      b += NEON_VECTOR_LENGTH;
+      pos -= NEON_VECTOR_LENGTH;
+      len -= NEON_VECTOR_LENGTH;
+    }
+  }
