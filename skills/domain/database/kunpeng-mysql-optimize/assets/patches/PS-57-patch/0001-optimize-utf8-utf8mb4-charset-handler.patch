+static size_t
+my_caseup_utf8mb4(const CHARSET_INFO *cs, char *src, size_t srclen,
+                  char *dst, size_t dstlen)
+{
+  my_wc_t wc;
+  int srcres, dstres;
+  char *srcend = src + srclen, *dstend = dst + dstlen, *dst0 = dst;
+  const MY_UNICASE_INFO *uni_plane = cs->caseinfo;
+  assert(src != dst || cs->caseup_multiply == 1);
+
+  if (my_simd_support_check(cs))
+  {
+    uint8x16_t vec_src;
+
+    while (src + NEON_VECTOR_LENGTH <= srcend &&
+           dst + NEON_VECTOR_LENGTH <= dstend)
+    {
+      if (!my_simd_load_ascii_vector((const uchar *)src, &vec_src))
+      {
+        break;
+      }
+
+      my_simd_toupper_ascii(&vec_src);
+      vst1q_u8((uchar *)dst, vec_src);
+
+      src += NEON_VECTOR_LENGTH;
+      dst += NEON_VECTOR_LENGTH;
+    }
+  }
+
+  while ((src < srcend) &&
+         (srcres = my_mb_wc_utf8mb4(cs, &wc,
+                                    (uchar *) src, (uchar*) srcend)) > 0)
+  {
+    my_toupper_utf8mb4(uni_plane, &wc);
+    if ((dstres = my_wc_mb_utf8mb4(cs, wc, (uchar *)dst, (uchar *)dstend)) <= 0)
