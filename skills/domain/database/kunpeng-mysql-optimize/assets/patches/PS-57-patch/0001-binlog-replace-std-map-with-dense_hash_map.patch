+   the table.
+</TD>
+<TD VAlign=top>
+   &nbsp;
+</TD>
+</TR>
+
+<TR>
+<TD VAlign=top>
+   <tt>GROUP_SIZE</tt>
+</TD>
+<TD VAlign=top>
