diff --git a/storage/innobase/include/rem0rec.h b/storage/innobase/include/rem0rec.h
index a7151c0a..df8dec9f 100644
--- a/storage/innobase/include/rem0rec.h
+++ b/storage/innobase/include/rem0rec.h
@@ -466,12 +466,41 @@ rec_get_offsets_func(
 	mem_heap_t**		heap)	/*!< in/out: memory heap */
 	MY_ATTRIBUTE((warn_unused_result));
 
+/******************************************************//**
+The following function determines the offsets to each field
+in the record.	It can reuse a previously allocated array.
+@return the new offsets */
+ulint*
+rec_get_offsets_func_with_comp(
+/*=================*/
+	const rec_t*		rec,	/*!< in: physical record */
+	const dict_index_t*	index,	/*!< in: record descriptor */
+	const ibool		compact,/*!< in: compact page format  */
+	ulint*			offsets,/*!< in/out: array consisting of
+					offsets[0] allocated elements,
+					or an array from rec_get_offsets(),
+					or NULL */
+	ulint			n_fields,/*!< in: maximum number of
+					initialized fields
+					 (ULINT_UNDEFINED if all fields) */
+#ifdef UNIV_DEBUG
+	const char*		file,	/*!< in: file name where called */
+	ulint			line,	/*!< in: line number where called */
+#endif /* UNIV_DEBUG */
+	mem_heap_t**		heap)	/*!< in/out: memory heap */
+	MY_ATTRIBUTE((warn_unused_result));
+
 #ifdef UNIV_DEBUG
 # define rec_get_offsets(rec,index,offsets,n,heap)			\
 	rec_get_offsets_func(rec,index,offsets,n,__FILE__,__LINE__,heap)
+# define rec_get_offsets_with_comp(rec,index,compact,offsets,n,heap)	\
+	rec_get_offsets_func_with_comp(rec, index, compact, offsets, n,	\
+				       __FILE__, __LINE__, heap)
 #else /* UNIV_DEBUG */
 # define rec_get_offsets(rec, index, offsets, n, heap)	\
 	rec_get_offsets_func(rec, index, offsets, n, heap)
+# define rec_get_offsets_with_comp(rec, index, compact, offsets, n, heap)\
+	rec_get_offsets_func_with_comp(rec, index, compact, offsets, n, heap)
 #endif /* UNIV_DEBUG */
 
 /******************************************************//**
