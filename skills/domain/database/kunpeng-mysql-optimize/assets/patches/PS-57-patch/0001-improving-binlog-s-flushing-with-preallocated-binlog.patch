 sql/binlog.h             | 30 ++++++++++++++++
 sql/log_event.cc         | 53 ++++++++++++++++++++++++++++
 sql/mysqld.cc            |  1 +
 sql/mysqld.h             |  1 +
 sql/rpl_binlog_sender.cc | 20 ++++++++++-
 sql/sys_vars.cc          |  6 ++++
 7 files changed, 185 insertions(+), 2 deletions(-)

