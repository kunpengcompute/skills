       LOG_INFO li;
       binary_log->get_current_log(&li, false /*LOCK_log is already acquired*/);
       end_pos= li.pos;
+      if (binary_log->log_preallocated(linfo.log_file_name)) {
+        /* Just keep consistent behaviour with no log preallocated, even though
+        current end_of_file is safer, */
+        log.end_of_file= end_pos;
+      }
     }
     else
