@@ -288,6 +291,37 @@ static void set_thd_db(THD *thd, const char *db, size_t db_len)
 
 #endif
 
+static bool is_buf_zeros(const char *buf, ssize_t buf_len) {
+  while (buf_len > 0) {
+    if(buf[buf_len - 1] != 0) {
+      return false;
+    }
+    buf_len--;
+  }
+
+  return true;
+}
+
+/**
+  Whether or not we reached a eof of preallocated binlog, usually, we only
+  invoke this function only once in crash recovery case, and this function
+  didn't change IO_CACHE's file position.
+  @param logfile  The IO_CACHE for binlog read.
+  @return true  if we have reached a end of preallocated file.
+*/
+static bool is_preallocated_log_eof(IO_CACHE *logfile) {
+  uchar log_io_block[IO_SIZE];
+
+  my_off_t org_position= my_tell(logfile->file, MYF(0));
+  my_off_t offset= my_b_tell(logfile);
+
+  my_off_t length= my_pread(logfile->file, log_io_block, IO_SIZE,
+                            offset, logfile->myflags | MY_NABP);
+
+  my_seek(logfile->file, org_position, MY_SEEK_SET, MYF(0));
+
+  return is_buf_zeros((char *)log_io_block, length);
+}
 
