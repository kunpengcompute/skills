index 014ffec37f4..0c576a404b7 100644
--- a/sql/binlog.cc
+++ b/sql/binlog.cc
@@ -3061,6 +3061,17 @@ File open_binlog_file(IO_CACHE *log, const char *log_file_name, const char **err
     *errmsg = "Could not open log file";
