     }
 
     /* this will cleanup IO_CACHE, sync and close the file */
@@ -10883,6 +10906,57 @@ void MYSQL_BIN_LOG::report_missing_gtids(const Gtid_set* previous_gtid_set,
   DBUG_VOID_RETURN;
 }
 
+void MYSQL_BIN_LOG::preallocate_log_file() {
+  if (opt_binlog_preallocate == FALSE || log_file.type != WRITE_CACHE) {
+    return;
+  }
+
+  assert(log_file.file != -1);
+#if defined(__aarch64__) && defined(__linux__)
+#if defined(FALLOC_FL_WRITE_ZEROS)
+  /* Some hardware support UMMAP bit or DEAC bit, which can accelerate
+  writting zeros. */
+  const static int BINLOG_FALLOCATE_MODE = FALLOC_FL_WRITE_ZEROS;
+#else
+  const static int BINLOG_FALLOCATE_MODE = FALLOC_FL_ZERO_RANGE;
+#endif
+  my_off_t offset= my_b_get_pos_in_file(&log_file);
+  my_off_t to_size= max_size;
+
+  assert(to_size <= max_size);
+  assert(to_size > offset);
+  int ret= fallocate(log_file.file, BINLOG_FALLOCATE_MODE, offset, to_size);
+  if(ret == 0) {
+    m_preallocated_log_size= to_size;
+    return;
+  }
+
+  sql_print_warning("failed to fallocate for binlog file: %s, error no: %d",
+                    log_file_name, ret);
+  if (m_preallocated_log_size <= offset) {
+    m_preallocated_log_size= 0;
+  }
+#endif
+}
+
+void MYSQL_BIN_LOG::reclain_preallocated_log_file() {
+  if (log_file.type != WRITE_CACHE) {
+    return;
+  }
+
+  my_off_t pos_written= my_b_get_pos_in_file(&log_file);
+  /* In some error cases, io cache maybe hasn't been flushed. */
+  assert(my_b_tell(&log_file) >= pos_written);
+  assert(log_file.file != -1);
+  if (m_preallocated_log_size > pos_written &&
+      ftruncate(log_file.file, pos_written) != 0) {
+    sql_print_error("failed to recalain for binlog file: %s, error no: %d",
+                    log_file_name, errno);
+  }
+
+  m_preallocated_log_size= 0;
+}
+
 bool THD::is_binlog_cache_empty(bool is_transactional)
 {
   DBUG_ENTER("THD::is_binlog_cache_empty(bool)");
diff --git a/sql/binlog.h b/sql/binlog.h
index 4dbf1476d34..34f44aba9ca 100644
--- a/sql/binlog.h
+++ b/sql/binlog.h
@@ -996,8 +996,38 @@ public:
   {
     return &crypto;
   }
+
+  bool log_preallocated(const char* log_name) {
+    if (is_active(log_name) && log_file.type == WRITE_CACHE) {
+      return m_preallocated_log_size > 0;
+    }
+
+    return false;
+  }
 private:
+  /*
+    The size of current preallocated binlog file size. When the binlog was
+    created, we will reallocated all physical block. If current binlog is
+    closed, we will reclain the preallocated physical block.
+
+    Testcases: Writting a full of binlog in Kunpen 920B PCIE 4.0 NVME SSD,
+    binlog size: 512MB
+
+    1. directly write(UNIT: 512(IO_SIZE)) costs: 1280ms
+
+    2. fallocated 512MB && write(512 bytes) costs: 650ms
+
+    3. fallocated a file with size of 512MB and zeros filling only costs 0.6ms
+    So with preallocated binlog, we can save 50% costs during binlog's flush
+    stage.
+  */
+  size_t m_preallocated_log_size;
+
   void publish_coordinates_for_global_status(void) const;
+
+  void preallocate_log_file();
+
+  void reclain_preallocated_log_file();
 };
 
