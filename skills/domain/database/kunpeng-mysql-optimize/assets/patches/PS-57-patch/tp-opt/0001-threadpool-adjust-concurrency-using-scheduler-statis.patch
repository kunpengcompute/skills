+class Tp_statistics
+{
+public:
+  Tp_statistics()
+    : m_n_cpu(-1),
+      m_active_threads_quota(INT_MAX),
+      m_time_pct(-1),
+      m_nivcsw_freq(0),
+      m_nvcsw_freq(0)
+  {
+  }
+
+  int time_pct() const
+  {
+    return (int)m_time_pct;
+  }
+
+  ulonglong nivcsw_freq() const
+  {
+    return (ulonglong)m_nivcsw_freq;
+  }
+
+  ulonglong nvcsw_freq() const
+  {
+    return (ulonglong)m_nvcsw_freq;
+  }
+
+  int active_threads_quota() const
+  {
+    return (int)m_active_threads_quota;
+  }
+
+  void to_cstring(char *buff, size_t buff_size) const
+  {
+    snprintf(buff, buff_size,
+             "n_cpu: %d, cpu_pct: %d, nivcsw_freq: %llu, nvcsw_freq: %llu, "
+             "active_threads_quota: %d",
+             (int)m_n_cpu, time_pct(),
+             (unsigned long long)nivcsw_freq(),
+             (unsigned long long)nvcsw_freq(),
+             active_threads_quota());
+  }
+
+  void reset()
+  {
+    m_n_cpu= -1;
+    m_active_threads_quota= tp_max_threads_quota();
+    m_time_pct= -1;
+    m_nivcsw_freq= 0;
+    m_nvcsw_freq= 0;
+  }
+
+  void update();
+
+private:
+  static longlong timeval_diff_us(const timeval &a, const timeval &b)
+  {
+    return ((longlong)a.tv_sec - (longlong)b.tv_sec) * 1000000LL +
+           (longlong)a.tv_usec - (longlong)b.tv_usec;
+  }
+
+  static int tp_max_threads_quota()
+  {
+    return (int)threadpool_oversubscribe * (int)threadpool_size;
+  }
+
+  static int tp_min_threads_quota()
+  {
+    return (int)threadpool_size * 2;
+  }
+
+  static int tp_get_num_cpus()
+  {
+    uint32 cpus= my_num_vcpus();
+    return cpus > 0 ? (int)cpus : 1;
+  }
+
+  static double thread_quota_scale_factor()
+  {
+    return 0.25;
+  }
+
+  void evaluate_active_threads_quota();
+
+private:
+  volatile int32 m_n_cpu;
+  volatile int32 m_active_threads_quota;
+  volatile int32 m_time_pct;
+  volatile int64 m_nivcsw_freq;
+  volatile int64 m_nvcsw_freq;
+};
+
+void Tp_statistics::update()
+{
+  static ulonglong last_time= 0;
+  static struct rusage last_cpu_usage;
+  const ulonglong current_time= my_microsecond_getsystime();
+  const ulonglong elapsed_us= current_time - last_time;
+  struct rusage usage;
+
+  if (getrusage(RUSAGE_SELF, &usage) != 0)
+    return;
+
+  if (m_n_cpu == -1)
+  {
+    last_time= current_time;
+    last_cpu_usage= usage;
+    m_time_pct= -1;
+    m_nivcsw_freq= 0;
+    m_nvcsw_freq= 0;
+    m_n_cpu= tp_get_num_cpus();
+    m_active_threads_quota= tp_min_threads_quota();
+    return;
+  }
+
+  if (elapsed_us == 0)
+    return;
+
+  const int n_cpu= std::max(1, (int)m_n_cpu);
+  const longlong utime_diff=
+    timeval_diff_us(usage.ru_utime, last_cpu_usage.ru_utime);
+  const longlong stime_diff=
+    timeval_diff_us(usage.ru_stime, last_cpu_usage.ru_stime);
+  const longlong nvcsw_diff=
+    std::max<longlong>(0LL, (longlong)usage.ru_nvcsw -
+                             (longlong)last_cpu_usage.ru_nvcsw);
+  const longlong nivcsw_diff=
+    std::max<longlong>(0LL, (longlong)usage.ru_nivcsw -
+                             (longlong)last_cpu_usage.ru_nivcsw);
+
+  last_time= current_time;
+  last_cpu_usage= usage;
+
+  const int cpu_time_pct=
+    (int)std::max(0.0, ((utime_diff + stime_diff) * 100.0 / elapsed_us) / n_cpu);
+  const ulonglong nivcsw_freq=
+    (ulonglong)std::max(0.0, (nivcsw_diff * 1000000.0 / elapsed_us) / n_cpu);
+  const ulonglong nvcsw_freq=
+    (ulonglong)std::max(0.0, (nvcsw_diff * 1000000.0 / elapsed_us) / n_cpu);
+
+  m_time_pct= cpu_time_pct;
+  m_nivcsw_freq= (int64)nivcsw_freq;
+  m_nvcsw_freq= (int64)nvcsw_freq;
+  evaluate_active_threads_quota();
+}
+
+void Tp_statistics::evaluate_active_threads_quota()
+{
+  const int cpu_time_pct= (int)m_time_pct;
+  const int cpu_usage_threshold= (int)threadpool_cpu_usage_threshold;
+  const ulonglong nvcsw_freq= (ulonglong)m_nvcsw_freq;
+  const ulonglong nivcsw_freq= (ulonglong)m_nivcsw_freq;
+  int active_threads_quota= (int)m_active_threads_quota;
+
+  if (cpu_time_pct <= 0)
+  {
+    m_active_threads_quota= tp_max_threads_quota();
+    return;
+  }
+
+  if (cpu_time_pct > cpu_usage_threshold ||
+      nvcsw_freq > threadpool_nvcsw_freq_threshold ||
+      nivcsw_freq > threadpool_nivcsw_freq_threshold)
+  {
+    const int min_active_threads_quota= tp_min_threads_quota();
+    const int max_active_threads_quota=
+      (int)(threadpool_size * threadpool_oversubscribe);
+    const int quota_delta=
+      std::max(1, (int)(threadpool_size * thread_quota_scale_factor()));
+
+    if (active_threads_quota >= (max_active_threads_quota / 2))
+    {
+      active_threads_quota= tp_min_threads_quota() + quota_delta;
+      if (active_threads_quota > tp_max_threads_quota())
+        active_threads_quota= tp_max_threads_quota();
+    }
+    else
+    {
+      active_threads_quota-= quota_delta;
+      if (active_threads_quota < min_active_threads_quota)
+        active_threads_quota= min_active_threads_quota;
+    }
+
+    m_active_threads_quota= active_threads_quota;
+  }
+  else
+  {
+    int evaluate_quota=
+      tp_global_active_threads_counter.load() * 100 / cpu_time_pct;
+
+    if (active_threads_quota < evaluate_quota)
+      active_threads_quota= evaluate_quota;
+    else
+      active_threads_quota+=
+        (int)(threadpool_size * thread_quota_scale_factor());
+
+    if (active_threads_quota > tp_max_threads_quota())
+      active_threads_quota= tp_max_threads_quota();
+
+    m_active_threads_quota= active_threads_quota;
+  }
+}
+
+static Tp_statistics tp_statistics;
+
