diff --git a/mysql-test/suite/sys_vars/t/thread_pool_cpu_usage_threshold_basic.test b/mysql-test/suite/sys_vars/t/thread_pool_cpu_usage_threshold_basic.test
new file mode 100644
index 00000000000..3511581ff96
--- /dev/null
+++ b/mysql-test/suite/sys_vars/t/thread_pool_cpu_usage_threshold_basic.test
@@ -0,0 +1,42 @@
+# uint global
+--source include/not_windows.inc
+--source include/not_embedded.inc
+SET @start_global_value = @@global.thread_pool_cpu_usage_threshold;
+
+#
+# exists as global only
+#
+select @@global.thread_pool_cpu_usage_threshold;
+--error ER_INCORRECT_GLOBAL_LOCAL_VAR
+select @@session.thread_pool_cpu_usage_threshold;
+show global variables like 'thread_pool_cpu_usage_threshold';
+show session variables like 'thread_pool_cpu_usage_threshold';
+select * from information_schema.global_variables where variable_name='thread_pool_cpu_usage_threshold';
+select * from information_schema.session_variables where variable_name='thread_pool_cpu_usage_threshold';
+
+#
+# show that it's writable
+#
+set global thread_pool_cpu_usage_threshold=0;
+select @@global.thread_pool_cpu_usage_threshold;
+set global thread_pool_cpu_usage_threshold=100;
+select @@global.thread_pool_cpu_usage_threshold;
+--error ER_GLOBAL_VARIABLE
+set session thread_pool_cpu_usage_threshold=1;
+
+#
+# incorrect types
+#
+--error ER_WRONG_TYPE_FOR_VAR
+set global thread_pool_cpu_usage_threshold=1.1;
+--error ER_WRONG_TYPE_FOR_VAR
+set global thread_pool_cpu_usage_threshold=1e1;
+--error ER_WRONG_TYPE_FOR_VAR
+set global thread_pool_cpu_usage_threshold="foo";
+
+set global thread_pool_cpu_usage_threshold=-1;
+select @@global.thread_pool_cpu_usage_threshold;
+set global thread_pool_cpu_usage_threshold=10000000000;
+select @@global.thread_pool_cpu_usage_threshold;
+
+set @@global.thread_pool_cpu_usage_threshold = @start_global_value;
