+
+static uint32 num_vcpus_using_config(void)
+{
+#if defined(_SC_NPROCESSORS_ONLN)
+  long num_vcpus= sysconf(_SC_NPROCESSORS_ONLN);
+#elif defined(_SC_NPROCESSORS_CONF)
+  long num_vcpus= sysconf(_SC_NPROCESSORS_CONF);
+#else
+  long num_vcpus= 0;
+#endif
+
+  return num_vcpus > 0 ? (uint32)num_vcpus : 0;
+}
+
+#ifdef __linux__
+static uint32 num_vcpus_using_affinity(void)
+{
+  cpu_set_t cpus;
+  CPU_ZERO(&cpus);
+
+  if (sched_getaffinity(getpid(), sizeof(cpus), &cpus) != 0)
+    return 0;
+
+  return (uint32)CPU_COUNT(&cpus);
+}
+
+static uint32 read_cgroup_v1_vcpu_limit(void)
+{
+  FILE *quota_file= fopen("/sys/fs/cgroup/cpu/cpu.cfs_quota_us", "r");
+  FILE *period_file= fopen("/sys/fs/cgroup/cpu/cpu.cfs_period_us", "r");
+  long long quota;
+  unsigned long long period;
+  uint32 limit= 0;
+
+  if (!quota_file || !period_file)
+    goto end;
+
+  if (fscanf(quota_file, "%lld", &quota) != 1 || quota < 0)
+    goto end;
+
+  if (fscanf(period_file, "%llu", &period) != 1 || period == 0)
+    goto end;
+
+  limit= (uint32)(quota / (long long)period);
+
+end:
+  if (quota_file)
+    fclose(quota_file);
+  if (period_file)
+    fclose(period_file);
+  return limit;
+}
+
+static uint32 read_cgroup_v2_vcpu_limit(void)
+{
+  FILE *cpu_file= fopen("/sys/fs/cgroup/cpu.max", "r");
+  char quota[64];
+  unsigned long long period;
+  uint32 limit= 0;
+
+  if (!cpu_file)
+    return 0;
+
+  if (fscanf(cpu_file, "%63s %llu", quota, &period) == 2 &&
+      !(quota[0] == 'm' && quota[1] == 'a' && quota[2] == 'x' &&
+        quota[3] == '\0') &&
+      period != 0)
+  {
+    limit= (uint32)(strtoull(quota, 0, 10) / period);
+  }
+
+  fclose(cpu_file);
+  return limit;
+}
+
+static uint32 my_cgroup_vcpu_limit(void)
+{
+  uint32 limit= read_cgroup_v2_vcpu_limit();
+  if (limit != 0)
+    return limit;
+
+  return read_cgroup_v1_vcpu_limit();
+}
+#else
+static uint32 num_vcpus_using_affinity(void)
+{
+  return 0;
+}
+
+static uint32 my_cgroup_vcpu_limit(void)
+{
+  return 0;
+}
+#endif
+
+static uint32 my_system_num_vcpus(void)
+{
+  uint32 num_vcpus= num_vcpus_using_affinity();
+  if (num_vcpus == 0)
+    num_vcpus= num_vcpus_using_config();
+
+  return num_vcpus;
+}
+
+uint32 my_num_vcpus(void)
+{
+  uint32 num_vcpus= my_cgroup_vcpu_limit();
+  if (num_vcpus == 0)
+    num_vcpus= my_system_num_vcpus();
+
+  return num_vcpus;
+}
