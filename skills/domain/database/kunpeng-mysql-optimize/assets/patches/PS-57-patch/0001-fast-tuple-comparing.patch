diff --git a/storage/innobase/include/rem0cmp.h b/storage/innobase/include/rem0cmp.h
index af4f15f153c..7b8cbc006da 100644
--- a/storage/innobase/include/rem0cmp.h
+++ b/storage/innobase/include/rem0cmp.h
@@ -41,6 +41,10 @@ Created 7/1/1994 Heikki Tuuri
 #include "rem0rec.h"
 #include <my_sys.h>
 
+/** The buffer size of partial fast record comparing. if the paritial comparing
+size is greater than this, we will disale it */
+const size_t PARTIAL_FAST_CMP_RECORD_SIZE = 255;
+
