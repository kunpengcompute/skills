+rec_init_fixed_offsets(const dict_index_t *index, ulint *offsets) {
+	rec_offs_make_valid(NULL, index, offsets);
+	rec_offs_base(offsets)[0] = REC_N_NEW_EXTRA_BYTES | REC_OFFS_COMPACT;
+	const ulint n_fields = rec_offs_n_fields(offsets);
+	ulint *field_end = rec_offs_base(offsets) + 1;
