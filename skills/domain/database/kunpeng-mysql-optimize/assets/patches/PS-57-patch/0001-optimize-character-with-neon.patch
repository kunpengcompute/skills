+#if defined(__aarch64__)
+static inline my_bool my_simd_support_check(const CHARSET_INFO *cs)
+{
+  if ((cs->state & MY_CS_UNICODE) && !(cs->state & MY_CS_NONASCII) &&
+      (cs->caseinfo == &my_unicase_default))
+  {
+    return 1;
+  }
+
+  return 0;
+}
+
+
+static inline my_bool my_simd_ascii_check(const uchar *src, uint8x16_t *vec_src)
+{
+  const uint8x16_t vec_max_ascii = vdupq_n_u8(0x7F);
+  uint8x16_t vec_res;
+
+  *vec_src = vld1q_u8(src);
+  // check if exists non-ascii character
+  // ascii -> non zero, non-ascii -> zero
+  vec_res = vcleq_u8(*vec_src, vec_max_ascii);
+  if (vminvq_u8(vec_res) == 0)
+  {
+    // has non-ascii character
+    return 0;
+  }
+
+  return 1;
+}
+
+
+static inline void my_simd_tosort_ascii(const CHARSET_INFO *cs,
+                                        uint8x16_t *vec_src,
+                                        const MY_UNICASE_INFO *uni_plane)
+{
+  const uint8x16_t vec_diff = vdupq_n_u8('a' - 'A');
+
+  if (uni_plane == NULL)
+  {
+    return;
+  }
+
+  if (cs->state & MY_CS_LOWER_SORT)
+  {
+    uint8x16_t vec_mask = vcgeq_u8(*vec_src, vdupq_n_u8('A')) &
+                              vcleq_u8(*vec_src, vdupq_n_u8('Z'));
+    *vec_src = vbslq_u8(vec_mask, vaddq_u8(*vec_src, vec_diff), *vec_src);
+  }
+  else
+  {
+    uint8x16_t vec_mask = vcgeq_u8(*vec_src, vdupq_n_u8('a')) &
+                              vcleq_u8(*vec_src, vdupq_n_u8('z'));
+    *vec_src = vbslq_u8(vec_mask, vsubq_u8(*vec_src, vec_diff), *vec_src);
+  }
+}
+
+
+static inline void my_simd_ascii_to_unicode(uint8x16_t *vec_src, uchar *dst)
+{
+  const size_t neon_vector_length = 16;
+  uint8x16_t vec_low = vreinterpretq_u8_u16(vmovl_u8(vget_low_u8(*vec_src)));
+  uint8x16_t vec_high = vreinterpretq_u8_u16(vmovl_u8(vget_high_u8(*vec_src)));
+
+  vec_low = vrev16q_u8(vec_low);
+  vec_high = vrev16q_u8(vec_high);
+
+  vst1q_u8(dst, vec_low);
+  vst1q_u8(dst + neon_vector_length, vec_high);
+}
+
+
+static inline void my_simd_toupper_ascii(uint8x16_t *vec_src)
+{
+
+  const uint8x16_t vec_diff = vdupq_n_u8('a' - 'A');
+  uint8x16_t vec_mask = vcgeq_u8(*vec_src, vdupq_n_u8('a')) &
+                            vcleq_u8(*vec_src, vdupq_n_u8('z'));
+  *vec_src = vbslq_u8(vec_mask, vsubq_u8(*vec_src, vec_diff), *vec_src);
+}
+
+
+static inline void my_simd_tolower_ascii(uint8x16_t *vec_src)
+{
+  const uint8x16_t vec_diff = vdupq_n_u8('a' - 'A');
+  uint8x16_t vec_mask = vcgeq_u8(*vec_src, vdupq_n_u8('A')) &
+                            vcleq_u8(*vec_src, vdupq_n_u8('Z'));
+  *vec_src = vbslq_u8(vec_mask, vaddq_u8(*vec_src, vec_diff), *vec_src);
+}
+
+
+static inline void my_simd_hash_cal(uint8x16_t *vec_src,
+                                    ulong *hash_val1, ulong *hash_val2)
+{
+  const size_t neon_vector_length = 16;
+  uchar dst[16];
+
+  vst1q_u8(dst, *vec_src);
+  for (size_t i = 0; i < neon_vector_length; i++)
+  {
+    *hash_val1 ^= (((*hash_val1 & 63) + *hash_val2) * dst[i]) +
+                      (*hash_val1 << 8);
+    *hash_val1 ^= (*hash_val1 << 8);
+    *hash_val2 += 6;
+  }
+}
+
+
+static inline int my_simd_vector_cmp(uint8x16_t *vec_first,
+                                     uint8x16_t *vec_second)
+{
+  uint8x16_t vec_cmp = vceqq_u8(*vec_first, *vec_second);
+  if (vminvq_u8(vec_cmp) != 0)
+  {
+    return 0;
+  }
+
+  vec_cmp = vcgtq_u8(*vec_first, *vec_second);
+  if (vmaxvq_u8(vec_cmp) != 0)
+  {
+    return 1;
+  }
+
+  return -1;
+}
+#endif
