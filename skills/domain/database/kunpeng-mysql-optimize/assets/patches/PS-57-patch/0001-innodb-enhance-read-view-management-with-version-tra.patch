From 45daf81caffa5a8329ddbac326728e58943e81c9 Mon Sep 17 00:00:00 2001
From: zhengyuanyue <im_zyy@hotmail.com>
Date: Thu, 5 Mar 2026 20:41:01 +0800
Subject: [PATCH] innodb: enhance read view management with version tracking

- Introduced a new versioning mechanism for read views to optimize reuse based on data changes.
- Updated trx_sys_t to include rw_trx_version for tracking the version of data used in read views.
- Modified ReadView to store and utilize the rw_trx_version for efficient view management.
- Adjusted locking behavior in ha_innobase::external_lock to improve performance during view closure.
---
 storage/innobase/handler/ha_innodb.cc |  6 +---
 storage/innobase/include/read0types.h | 10 ++++++
 storage/innobase/include/trx0sys.h    |  3 ++
 storage/innobase/read/read0read.cc    | 49 ++++++++++++++++++++-------
 storage/innobase/trx/trx0trx.cc       |  8 ++++-
 5 files changed, 57 insertions(+), 19 deletions(-)

diff --git a/storage/innobase/handler/ha_innodb.cc b/storage/innobase/handler/ha_innodb.cc
index fc9712943..4bfe2c7de 100644
--- a/storage/innobase/handler/ha_innodb.cc
+++ b/storage/innobase/handler/ha_innodb.cc
@@ -17566,11 +17566,7 @@ ha_innobase::external_lock(
 		} else if (trx->isolation_level <= TRX_ISO_READ_COMMITTED
 			   && MVCC::is_view_active(trx->read_view)) {
 
-			mutex_enter(&trx_sys->mutex);
-
-			trx_sys->mvcc->view_close(trx->read_view, true);
-
-			mutex_exit(&trx_sys->mutex);
+			trx_sys->mvcc->view_close(trx->read_view, false);
 		}
 	}
 
diff --git a/storage/innobase/include/read0types.h b/storage/innobase/include/read0types.h
index 4f1c6f658..c7b0c5bff 100644
--- a/storage/innobase/include/read0types.h
+++ b/storage/innobase/include/read0types.h
@@ -251,6 +251,13 @@ public:
 		return(m_ids.empty());
 	}
 
+	/**
+	@return the version of this view */
+	ulint version() const
+	{
+		return(m_version);
+	}
+
 	/**
 	Clones a read view object. The resulting read view has identical change
 	visibility as the donor read view
@@ -369,6 +376,9 @@ private:
 	/** List of read views in trx_sys */
 	byte		pad1[64 - sizeof(node_t)];
 	node_t		m_view_list;
+
+	/** Version of this view */
+	ulint m_version;
 };
 
 #endif
diff --git a/storage/innobase/include/trx0sys.h b/storage/innobase/include/trx0sys.h
index f7fa1f906..458945c6f 100644
--- a/storage/innobase/include/trx0sys.h
+++ b/storage/innobase/include/trx0sys.h
@@ -649,6 +649,9 @@ struct trx_sys_t {
 					while there were XA PREPARED
 					transactions. We disable query cache
 					if such transactions exist. */
+	volatile ulint	readview_version;	/*!< version of to build
+					read views without holding any
+					mutex */
 };
 
 /** When a trx id which is zero modulo this number (which must be a power of
diff --git a/storage/innobase/read/read0read.cc b/storage/innobase/read/read0read.cc
index 4b7b9547b..99b525e35 100644
--- a/storage/innobase/read/read0read.cc
+++ b/storage/innobase/read/read0read.cc
@@ -335,7 +335,8 @@ ReadView::ReadView()
 	m_creator_trx_id(),
 	m_ids(),
 	m_low_limit_no(),
-	m_cloned(false)
+	m_cloned(false),
+	m_version()
 {
 	ut_d(::memset(&m_view_list, 0x0, sizeof(m_view_list)));
 }
@@ -482,6 +483,8 @@ ReadView::prepare(trx_id_t id)
 		m_ids.clear();
 	}
 
+	m_version = trx_sys->readview_version;
+
 	if (UT_LIST_GET_LEN(trx_sys->serialisation_list) > 0) {
 		const trx_t*	trx;
 
@@ -575,8 +578,8 @@ MVCC::view_open(ReadView*& view, trx_t* trx)
 {
 	ut_ad(!srv_read_only_mode);
 
-	/** If no new RW transaction has been started since the last view
-	was created then reuse the the existing view. */
+	/** If the data used to build the previous view hasn't changed,
+	reuse the existing view. */
 	if (view != NULL) {
 
 		uintptr_t	p = reinterpret_cast<uintptr_t>(view);
@@ -586,24 +589,25 @@ MVCC::view_open(ReadView*& view, trx_t* trx)
 		ut_ad(view->m_closed);
 
 		/* NOTE: This can be optimised further, for now we only
-		resuse the view iff there are no active RW transactions.
+		reuse the view if the source data used to build the view
+		has not changed.
 
 		There is an inherent race here between purge and this
 		thread. Purge will skip views that are marked as closed.
-		Therefore we must set the low limit id after we reset the
-		closed status after the check. */
-
-		if (trx_is_autocommit_non_locking(trx) && view->empty()) {
+		Therefore we must reset the closed status before the
+		check. */
 
+		if (view->version() == trx_sys->readview_version) {
 			view->m_closed = false;
-
-			if (view->m_low_limit_id == trx_sys_get_max_trx_id()) {
+			ulint	readview_version = os_atomic_increment_ulint(
+				&trx_sys->readview_version, 0);
+			if (view->version() == readview_version) {
 				return;
-			} else {
-				view->m_closed = true;
 			}
 		}
 
+		view->m_closed = true;
+
 		mutex_enter(&trx_sys->mutex);
 
 		UT_LIST_REMOVE(m_views, view);
@@ -674,6 +678,8 @@ ReadView::copy_prepare(const ReadView& other)
 	m_low_limit_id = other.m_low_limit_id;
 
 	m_creator_trx_id = other.m_creator_trx_id;
+
+	m_version = other.m_version;
 }
 
 /**
@@ -763,7 +769,24 @@ MVCC::clone_oldest_view(ReadView* view)
 {
 	mutex_enter(&trx_sys->mutex);
 
-	ReadView*	oldest_view = get_oldest_view();
+	ReadView *oldest_view;
+	for (oldest_view = UT_LIST_GET_LAST(m_views); oldest_view != NULL;
+		oldest_view = UT_LIST_GET_PREV(m_view_list, oldest_view)) {
+		if (!oldest_view->is_closed()) {
+			if (oldest_view->low_limit_no() <= view->low_limit_no()) {
+				/* We won't gain anything by switching to oldest_view - as purge will
+				not be able to move any further than low_limit_no(). More importantly,
+				switching to oldest_view poses a risk of a crash, if it saw a strictly
+				smaller subset of transaction than view. Thankfully, we can prove the
+				later case happens only when a transaction is considering to reopen the
+				oldest_view, but will decide not to do it, so we can - and should! -
+				ignore it. */
+				trx_sys_mutex_exit();
+				return;
+			}
+			break;
+		}
+	}
 
 	if (oldest_view == NULL) {
 
diff --git a/storage/innobase/trx/trx0trx.cc b/storage/innobase/trx/trx0trx.cc
index 3332ef8ae..0352bc293 100644
--- a/storage/innobase/trx/trx0trx.cc
+++ b/storage/innobase/trx/trx0trx.cc
@@ -1318,6 +1318,9 @@ trx_assign_id_for_rw(trx_t* trx)
 {
 	ut_ad(mutex_own(&trx_sys->mutex));
 
+	/* Bump the version before changing any data used to build read views. */
+	os_atomic_increment_ulint(&trx_sys->readview_version, 1);
+
 	trx->id = trx->preallocated_id
 		? trx->preallocated_id : trx_sys_get_new_trx_id();
 
@@ -1919,6 +1922,9 @@ trx_erase_lists(
 	ut_ad(trx->id > 0);
 	trx_sys_mutex_enter();
 
+	/* Bump the version before changing any data used to build read views. */
+	os_atomic_increment_ulint(&trx_sys->readview_version, 1);
+
 	if (serialised) {
 		UT_LIST_REMOVE(trx_sys->serialisation_list, trx);
 	}
@@ -2364,7 +2370,7 @@ trx_clone_read_view(
 	}
 
 	if (from_trx->state != TRX_STATE_ACTIVE ||
-	    from_trx->read_view == NULL) {
+	    !MVCC::is_view_active(from_trx->read_view)) {
 
 		trx_sys_mutex_exit();
 		trx_mutex_exit(from_trx);
