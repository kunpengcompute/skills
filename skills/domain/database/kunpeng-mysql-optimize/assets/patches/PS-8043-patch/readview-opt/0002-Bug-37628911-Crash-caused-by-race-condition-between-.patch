+        updating purge's view is the right decision here. */
+        trx_sys_mutex_exit();
+        return;
+      }
+      break;
+    }
+  }
 
   if (oldest_view == nullptr) {
     view->prepare(0);
@@ -761,10 +884,6 @@ void MVCC::clone_oldest_view(ReadView *view) {
 
     view->copy_complete();
   }
