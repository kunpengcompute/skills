From fd8a37e2bac3a4428156157bc11dc88ebe819548 Mon Sep 17 00:00:00 2001
From: Ramakrishnan Kamalakannan <ramakrishnan.kamalakannan@oracle.com>
Date: Wed, 4 Jun 2025 14:03:18 +0200
Subject: [PATCH 3/3] Bug#37993516  Handle cgroup v1 default memory limit
 [post-push fix]

Description:
  Windows build fails as unistd.h is not available: symbols like sysconf
and _SC_PAGESIZE are undeclared.

Fix: Ensure that these symbols are used only when unistd.h is included.
Change-Id: Iec30573d1a4bdc0ed4e2fa5a2168900e3a34232e
(cherry picked from commit a56d4d7fb2218aa2d3819fee785d444da09d5c89)
---
 components/library_mysys/my_system_api/my_system_api_cgroup.cc | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/components/library_mysys/my_system_api/my_system_api_cgroup.cc b/components/library_mysys/my_system_api/my_system_api_cgroup.cc
index 77e953617..30338a392 100644
--- a/components/library_mysys/my_system_api/my_system_api_cgroup.cc
+++ b/components/library_mysys/my_system_api/my_system_api_cgroup.cc
@@ -111,6 +111,7 @@ std::optional<uint64_t> cgroup_v1_memory() {
     return std::nullopt;
   }
 
+#ifdef HAVE_UNISTD_H
   const long page_size = sysconf(_SC_PAGESIZE);
   assert(page_size > 0);
 
@@ -119,6 +120,8 @@ std::optional<uint64_t> cgroup_v1_memory() {
 
   /* Treat default value as no limits and return 0 */
   return (memory == default_limit) ? 0 : memory;
+#endif
+  return memory;
 }
 
