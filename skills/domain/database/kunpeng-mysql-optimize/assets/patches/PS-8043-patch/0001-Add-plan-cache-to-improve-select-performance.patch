diff --git a/mysql-test/suite/sys_vars/t/plan_cache_allow_change_ratio.test b/mysql-test/suite/sys_vars/t/plan_cache_allow_change_ratio.test
new file mode 100644
index 000000000..65b1d0a07
--- /dev/null
+++ b/mysql-test/suite/sys_vars/t/plan_cache_allow_change_ratio.test
@@ -0,0 +1,134 @@
+############## mysql-test\t\plan_cache_allow_change_ratio.test ################
+#                                                                             #
+# Variable Name: plan_cache_allow_change_ratio                                #
+# Scope: GLOBAL                                                               #
+# Access Type: Session                                                        #
+# Data Type: double                                                           #
+# Default Value:0.2                                                           #
+# Range: 0-DBL_MAX                                                            #
+#                                                                             #
+# Description: Test Cases of Dynamic System Variable                          #
+#              plan_cache_allow_change_ratio that checks the behavior         #
+#              of this variable in the following ways                         #
+#              * Default Value                                                #
+#              * Valid & Invalid values                                       #
+#              * Scope & Access method                                        #
+#              * Data Intergrity                                              #
+#                                                                             #
+###############################################################################
+
+--source include/load_sysvars.inc
+
+########################################################################
+#              START OF plan_cache_allow_change_ratio TESTS            #
+########################################################################
+SET @start_plan_cache_allow_change_ratio = @@session.plan_cache_allow_change_ratio;
+SELECT @start_plan_cache_allow_change_ratio;
+
+########################################################################
+#      Display the DEFAULT value of plan_cache_allow_change_ratio      #
+########################################################################
+SET @@session.plan_cache_allow_change_ratio = 2;
+SET @@session.plan_cache_allow_change_ratio = DEFAULT;
+SELECT @@session.plan_cache_allow_change_ratio;
+
+###############################################
+#     Verify default value of variable        #
+###############################################
+SET @@plan_cache_allow_change_ratio = @start_plan_cache_allow_change_ratio;
+SELECT @@plan_cache_allow_change_ratio = 0.2;
+
+############################################################################
+#    Change the value of plan_cache_allow_change_ratio to a valid value    #
+############################################################################
+SET @@session.plan_cache_allow_change_ratio = 0;
+SELECT @@session.plan_cache_allow_change_ratio;
+SET @@session.plan_cache_allow_change_ratio = 1;
+SELECT @@session.plan_cache_allow_change_ratio;
+SET @@session.plan_cache_allow_change_ratio = 0.5;
+SELECT @@session.plan_cache_allow_change_ratio;
+SET @@session.plan_cache_allow_change_ratio = 100;
+SELECT @@session.plan_cache_allow_change_ratio;
+SET @@session.plan_cache_allow_change_ratio = -1;
+SELECT @@session.plan_cache_allow_change_ratio;
+SET @@session.plan_cache_allow_change_ratio = DEFAULT;
+SELECT @@session.plan_cache_allow_change_ratio;
+
+SET @@global.plan_cache_allow_change_ratio = 0;
+SELECT @@global.plan_cache_allow_change_ratio;
+SET @@global.plan_cache_allow_change_ratio = 1;
+SELECT @@global.plan_cache_allow_change_ratio;
+SET @@global.plan_cache_allow_change_ratio = 0.5;
+SELECT @@global.plan_cache_allow_change_ratio;
+SET @@global.plan_cache_allow_change_ratio = 100;
+SELECT @@global.plan_cache_allow_change_ratio;
+SET @@global.plan_cache_allow_change_ratio = -1;
+SELECT @@global.plan_cache_allow_change_ratio;
+SET @@global.plan_cache_allow_change_ratio = DEFAULT;
+SELECT @@global.plan_cache_allow_change_ratio;
+
+############################################################################
+#    Change the value of plan_cache_allow_change_ratio to invalid value    #
+############################################################################
+--Error ER_WRONG_TYPE_FOR_VAR
+SET @@global.plan_cache_allow_change_ratio = ON;
+SELECT @@global.plan_cache_allow_change_ratio;
+--Error ER_WRONG_TYPE_FOR_VAR
+SET @@global.plan_cache_allow_change_ratio = 'test';
+SELECT @@global.plan_cache_allow_change_ratio;
+--Error ER_WRONG_TYPE_FOR_VAR
+SET @@session.plan_cache_allow_change_ratio = ' ';
+SELECT @@session.plan_cache_allow_change_ratio;
+
+############################################################################
+#     Check if the value in GLOBAL & SESSION Tables values in variable     #
+############################################################################
+--disable_warnings
+SELECT @@global.plan_cache_allow_change_ratio = VARIABLE_VALUE
+FROM performance_schema.global_variables
+WHERE VARIABLE_NAME='plan_cache_allow_change_ratio';
+
+SELECT @@session.plan_cache_allow_change_ratio = VARIABLE_VALUE
+FROM performance_schema.session_variables
+WHERE VARIABLE_NAME='plan_cache_allow_change_ratio';
+--enable_warnings
+
+############################################################################
+#          Check if TRUE and FALSE values can be used on variable          #
+############################################################################
+SET @@session.plan_cache_allow_change_ratio = TRUE;
+SELECT @@session.plan_cache_allow_change_ratio;
+SET @@session.plan_cache_allow_change_ratio = FALSE;
+SELECT @@session.plan_cache_allow_change_ratio;
+
+###################################################################################################################
+#        Check if accessing variable with SESSION,LOCAL and without SCOPE points to same session variable         #
+###################################################################################################################
+SET @@global.plan_cache_allow_change_ratio = 100;
+SELECT @@plan_cache_allow_change_ratio = @@global.plan_cache_allow_change_ratio;
+
+#################################################################################################
+#        Check if plan_cache_allow_change_ratio can be accessed with and without @@ sign        #
+#################################################################################################
+--Error ER_PARSE_ERROR
+SET local.plan_cache_allow_change_ratio = 7;
+--Error ER_UNKNOWN_TABLE
+SELECT local.plan_cache_allow_change_ratio;
+--Error ER_PARSE_ERROR
+SET global.plan_cache_allow_change_ratio = 8;
+--Error ER_UNKNOWN_TABLE
+SELECT global.plan_cache_allow_change_ratio;
+--Error ER_BAD_FIELD_ERROR
+SELECT plan_cache_allow_change_ratio = @@session.plan_cache_allow_change_ratio;
+
+###########################################
+#          Restore initial value          #
+###########################################
+SET @@global.plan_cache_allow_change_ratio = @start_plan_cache_allow_change_ratio;
+SELECT @@global.plan_cache_allow_change_ratio;
+SET @@session.plan_cache_allow_change_ratio = @start_plan_cache_allow_change_ratio;
+SELECT @@session.plan_cache_allow_change_ratio;
+
+############################################################
+#        END OF plan_cache_allow_change_ratio TESTS        #
+############################################################
