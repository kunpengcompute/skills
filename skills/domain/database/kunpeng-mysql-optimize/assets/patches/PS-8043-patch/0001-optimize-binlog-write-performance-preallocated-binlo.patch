 }
 
+void IO_CACHE_ostream::preallocate_file(size_t file_size [[maybe_unused]]) {
+#if defined(__aarch64__) && defined (__linux__)
+#if defined(FALLOC_FL_WRITE_ZEROS)
+  /* Some hardware support UMMAP bit or DEAC bit, which can accelerate
+  writting zeros. */
+  const static int BINLOG_FALLOCATE_MODE = FALLOC_FL_WRITE_ZEROS;
+#else
+  const static int BINLOG_FALLOCATE_MODE = FALLOC_FL_ZERO_RANGE;
+#endif
+  my_off_t offset = my_b_get_pos_in_file(&m_io_cache);
+  my_off_t to_size = file_size;
+
+  assert(to_size <= file_size);
+  assert(to_size > offset);
+  int ret = fallocate(m_io_cache.file, BINLOG_FALLOCATE_MODE, offset, to_size);
+  if(ret == 0) {
+    m_preallocated_size = to_size;
+    return;
+  }
+
+  sql_print_warning("failed to fallocate for file: %d, error no: %d",
+                    m_io_cache.file, ret);
+  if (m_preallocated_size <= offset) {
+    m_preallocated_size = 0;
+  }
+#endif /** end of  defined(__aarch64__) && defined (__linux__) */
+}
+
+void IO_CACHE_ostream::reclaim_preallocated_file() {
+  my_off_t pos_written = my_b_get_pos_in_file(&m_io_cache);
+  /* In some error cases, io cache maybe hasn't been flushed. */
+  assert(my_b_tell(&m_io_cache) >= pos_written);
+  assert(m_io_cache.file != -1);
+  if (m_preallocated_size > pos_written &&
+    ftruncate(m_io_cache.file, pos_written) != 0) {
+    sql_print_error("failed to recalain for binlog file: %d, error no: %d",
+                    m_io_cache.file, errno);
+  }
+
+  m_preallocated_size = 0;
+}
+
+
 bool Compressed_ostream::write(const unsigned char *buffer, my_off_t length) {
   DBUG_TRACE;
   m_compressor->feed(buffer, length);
