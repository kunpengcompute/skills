+/** Fetch the 'record' only contains fields participated in comparing from
+ the complete dtuple record.
+ @param[in]     index       the index owned the record
+ @param[in]     dtuple      the complete dtuple record
+ @param[out]    size        the size of 'fast cmp rec'
+ @param[in]     buf         the memory buffer for the 'fast cmp rec' if needed
+ @param[in]     buf_size    the buffer size.
+ @return  the partial record of dtuple for comparing. */
+ALWAYS_INLINE byte* dtuple_fetch_partial_cmp_rec(const dict_index_t *index,
+  const dtuple_t *dtuple,
+  ulint *size, byte* buf,
+  ulint buf_size) {
+  ut_ad(size != nullptr);
+  ut_ad(buf != nullptr);
+  byte *last_pos = nullptr;
+  bool inplace_rec = true;
+
+  ulint info_bits = dtuple_get_info_bits(dtuple);
+
+  if (!index->cached || !dict_table_is_comp(index->table) ||
+      index->has_instant_cols_or_row_versions() || dtuple->n_fields == 0 ||
+      (info_bits & REC_INFO_MIN_REC_FLAG)) {
+    return nullptr;
+  }
+
+  *size = 0;
+
+  for (ulint i = 0; i < dtuple_get_n_fields_cmp(dtuple); i++) {
+    const dfield_t *dfield = dtuple_get_nth_field(dtuple, i);
+    const dtype_t *field_type = dfield_get_type(dfield);
+    const dict_field_t *field = index->get_field(i);
+
+    if (dfield->len != field->fixed_len || !(field->col->prtype & DATA_NOT_NULL) ||
+        !dtype_is_memcmp_deterministric(field_type) || dfield_is_multi_value(dfield) ||
+        !field->is_ascending) {
+      return nullptr;
+    }
+
+    if (inplace_rec && i < dtuple_get_n_fields_cmp(dtuple) - 1) {
+      last_pos = static_cast<byte *>(dfield->data);
+      byte* next_field = static_cast<byte *>(dtuple_get_nth_field(dtuple, i + 1)->data);
+
+      /* those fields in record is not continus, should copy those fields into buf. */
+      if (last_pos + dfield->len != next_field) {
+        inplace_rec = false;
+      }
+    }
+
+    *size += dfield->len;
+  }
+
+  if (inplace_rec) {
+    return static_cast<byte *>(dtuple_get_nth_field(dtuple, 0)->data);
+  }
+
+  if (*size > buf_size) {
+    return nullptr;
+  }
+
+  byte *ptr = buf;
+  for (ulint i = 0; i < dtuple_get_n_fields_cmp(dtuple); i++) {
+    const dfield_t *dfield = dtuple_get_nth_field(dtuple, i);
+    ut_memcpy(ptr, dfield->data, dfield->len);
+    ptr += dfield->len;
+  }
+
+  return buf;
+}
+
+/** Directly compare record's memory without collocation.
+ @param[in]   rec1          the first record for memory comparing
+ @param[in]   rec2          the second record for memory comparing
+ @param[in]   len           the minimum length of the comparing records
+ @param[out]  matched_bytes matched length the two records.
+ @return  the memory comparing result. */
+static inline int rec_direct_memcmp(const byte *rec1, const byte *rec2,
+                                    ulint len, ulint *matched_bytes) {
+  ut_ad(matched_bytes != nullptr);
+  for (ulint i = 0; i < len; i++) {
+    int cmp =  (int)(*rec1) - (int)(*rec2);
+    if (cmp != 0) {
+      *matched_bytes = i;
+      return cmp;
+    }
+
+    rec1++;
+    rec2++;
+  }
+
+  *matched_bytes = len;
+  return 0;
+}
+
+/** convert matched fields to matched bytes in dtuple record comparing.
+ @param[in]   dtuple          the tuple record.
+ @param[in]   matched_fields  the comparing matched fields in tuple comparing.
+ @return matched bytes. */
+static inline int dtuple_matched_fields_to_bytes(const dtuple_t *dtuple,
+                                                 ulint matched_fields) {
+  ulint matched_bytes = 0;
+  ut_ad(matched_fields <= dtuple_get_n_fields_cmp(dtuple));
+
+  for (ulint i = 0; i < matched_fields; i++) {
+    matched_bytes += dtuple_get_nth_field(dtuple, i)->len;
+  }
+
+  return matched_bytes;
+}
+
+/** convert matched bytes to matched fields in dtuple record comparing.
+ @param[in]   dtuple        the tuple record.
+ @param[in]   matched_bytes the comparing matched bytes in tuple comparing.
+ @return matched fields. */
+static inline int dtuple_matched_bytes_to_fields(const dtuple_t *dtuple,
+                                                 ulint matched_bytes) {
+  ulint matched_fields = 0;
+
+  for (; matched_fields < dtuple_get_n_fields_cmp(dtuple); matched_fields++) {
+
+    const dfield_t *dfield = dtuple_get_nth_field(dtuple, matched_fields);
+    if (matched_bytes < dfield->len) {
+      return matched_fields;
+    }
+
+    matched_bytes -= dfield->len;
+  }
+
+  return matched_fields;
+}
+
 #endif /* UNIV_HOTBACKUP */
