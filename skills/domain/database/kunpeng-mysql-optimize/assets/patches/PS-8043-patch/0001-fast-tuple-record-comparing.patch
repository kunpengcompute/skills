+/** Whether or not the type is deterministric in memory conparing.
+ @param[in]   dtype   the dtype of one dtuple.
+ @return  true  if the dtype is deterministric in memory comparing. */
+static ALWAYS_INLINE bool dtype_is_memcmp_deterministric(const dtype_t *&dtype) {
+  switch (dtype->mtype) {
+    case DATA_FIXBINARY:
+    case DATA_BINARY:
+    case DATA_INT:
+    case DATA_SYS_CHILD:
+    case DATA_SYS:
+      return true;
+
+    case DATA_POINT:
+    case DATA_VAR_POINT:
+    case DATA_GEOMETRY: {
+      if (dtype->prtype & DATA_GIS_MBR) {
+        return false;
+      }
+
+      return true;
+    }
+
+    case DATA_BLOB: {
+      if (dtype->prtype & DATA_BINARY_TYPE) {
+        return true;
+      }
+
+      return false;
+    }
+
+    default:
+      return false;
+  }
+
+  return false;
+}
