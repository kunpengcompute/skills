+#if defined(__aarch64__) && defined(__linux__)
+[[nodiscard]] ulint *rec_get_offsets_with_comp(const rec_t *rec, bool compact,
+                                               const dict_index_t *index,
+                                               ulint *offsets, ulint n_fields,
+                                               ut::Location location,
+                                               mem_heap_t **heap);
