+class Tp_statistics {
+ public:
+  int time_pct() const noexcept {
+    return m_time_pct.load(std::memory_order_relaxed);
+  }
+
+  ulonglong nivcsw_freq() const noexcept {
+    return m_nivcsw_freq.load(std::memory_order_relaxed);
+  }
+
+  ulonglong nvcsw_freq() const noexcept {
+    return m_nvcsw_freq.load(std::memory_order_relaxed);
+  }
+
+  int active_threads_quota() const noexcept {
+    return m_active_threads_quota.load(std::memory_order_relaxed);
+  }
+
+  void to_cstring(char *buff, size_t buff_size) const noexcept {
+    snprintf(buff, buff_size,
+             "n_cpu: %d, cpu_pct: %d, nivcsw_freq: %llu, nvcsw_freq: %llu, "
+             "active_threads_quota: %d",
+             m_n_cpu.load(std::memory_order_relaxed), time_pct(),
+             static_cast<unsigned long long>(nivcsw_freq()),
+             static_cast<unsigned long long>(nvcsw_freq()),
+             active_threads_quota());
+  }
+
+  void reset() noexcept {
+    m_n_cpu.store(kInvalidValue, std::memory_order_relaxed);
+    m_active_threads_quota.store(tp_max_threads_quota(),
+                                 std::memory_order_relaxed);
+    m_time_pct.store(kInvalidValue, std::memory_order_relaxed);
+    m_nivcsw_freq.store(0, std::memory_order_relaxed);
+    m_nvcsw_freq.store(0, std::memory_order_relaxed);
+  }
+
+  void update() noexcept;
+
+ private:
+  static constexpr int kInvalidValue{-1};
+
+  void evaluate_active_threads_quota() noexcept;
+
+  static longlong timeval_diff_us(const timeval &a, const timeval &b) noexcept {
+    return (static_cast<longlong>(a.tv_sec) - static_cast<longlong>(b.tv_sec)) *
+               1000000LL +
+           static_cast<longlong>(a.tv_usec) - static_cast<longlong>(b.tv_usec);
+  }
+
+  static int tp_max_threads_quota() noexcept {
+    /*
+      Reserve one active thread per group, since the per-group threshold is
+      threadpool_oversubscribe + 1.
+    */
+    return static_cast<int>(threadpool_oversubscribe) * threadpool_size;
+  }
+
+  static uint tp_min_threads_quota() noexcept { return threadpool_size; }
+
+  static double thread_quota_scale_factor() noexcept {
+    constexpr double kMinScaleFactor = 0.25;
+    return kMinScaleFactor;
+  }
+
+  /* Number of CPUs used to normalize the process CPU percentage. */
+  std::atomic<int> m_n_cpu{kInvalidValue};
+  /* Target active threads quota, capped by threadpool_oversubscribe. */
+  std::atomic<int> m_active_threads_quota{INT_MAX};
+  /* Process CPU percentage over the most recent sampling window. */
+  std::atomic<int> m_time_pct{kInvalidValue};
+  /* Passive context-switch frequency in counts per second per vCPU. */
+  std::atomic<ulonglong> m_nivcsw_freq{0};
+  /* Voluntary context-switch frequency in counts per second per vCPU. */
+  std::atomic<ulonglong> m_nvcsw_freq{0};
+};
+
+void Tp_statistics::update() noexcept {
+  using Clock = std::chrono::steady_clock;
+  const auto RELAX_ORDER = std::memory_order_relaxed;
+
+  static auto last_time = Clock::now();
+  static struct rusage last_cpu_usage {};
+
+  const auto current_time = Clock::now();
+  const auto elapsed_us = std::chrono::duration_cast<std::chrono::microseconds>(
+                              current_time - last_time)
+                              .count();
+  struct rusage usage;
+  if (getrusage(RUSAGE_SELF, &usage) != 0) return;
+
+  const int n_cpu = std::max(1, static_cast<int>(my_num_vcpus()));
+  if (m_n_cpu.load(RELAX_ORDER) == kInvalidValue) {
+    last_time = current_time;
+    last_cpu_usage = usage;
+    m_time_pct.store(kInvalidValue, RELAX_ORDER);
+    m_nivcsw_freq.store(0, RELAX_ORDER);
+    m_nvcsw_freq.store(0, RELAX_ORDER);
+    m_n_cpu.store(n_cpu, RELAX_ORDER);
+    m_active_threads_quota.store(tp_min_threads_quota(), RELAX_ORDER);
+    return;
+  }
+
+  if (elapsed_us <= 0) return;
+
+  const longlong utime_diff =
+      timeval_diff_us(usage.ru_utime, last_cpu_usage.ru_utime);
+  const longlong stime_diff =
+      timeval_diff_us(usage.ru_stime, last_cpu_usage.ru_stime);
+  const longlong nvcsw_diff =
+      std::max<longlong>(0, static_cast<longlong>(usage.ru_nvcsw) -
+                                static_cast<longlong>(last_cpu_usage.ru_nvcsw));
+  const longlong nivcsw_diff = std::max<longlong>(
+      0, static_cast<longlong>(usage.ru_nivcsw) -
+             static_cast<longlong>(last_cpu_usage.ru_nivcsw));
+
+  last_time = current_time;
+  last_cpu_usage = usage;
+
+  const int cpu_time_pct = static_cast<int>(
+      std::max(0.0, ((utime_diff + stime_diff) * 100.0 / elapsed_us) / n_cpu));
+
+  const ulonglong nivcsw_freq = static_cast<ulonglong>(
+      std::max(0.0, (nivcsw_diff * 1000000.0 / elapsed_us) / n_cpu));
+  const ulonglong nvcsw_freq = static_cast<ulonglong>(
+      std::max(0.0, (nvcsw_diff * 1000000.0 / elapsed_us) / n_cpu));
+
+  m_time_pct.store(cpu_time_pct, RELAX_ORDER);
+  m_nivcsw_freq.store(nivcsw_freq, RELAX_ORDER);
+  m_nvcsw_freq.store(nvcsw_freq, RELAX_ORDER);
+  evaluate_active_threads_quota();
+}
+
+void Tp_statistics::evaluate_active_threads_quota() noexcept {
+  const auto RELAX_ORDER = std::memory_order_relaxed;
+  const int cpu_time_pct = m_time_pct.load(RELAX_ORDER);
+  const int cpu_usage_threshold =
+      static_cast<int>(threadpool_cpu_usage_threshold);
+  const ulonglong nvcsw_freq = m_nvcsw_freq.load(RELAX_ORDER);
+  const ulonglong nivcsw_freq = m_nivcsw_freq.load(RELAX_ORDER);
+  int active_threads_quota = m_active_threads_quota.load(RELAX_ORDER);
+
+  /*
+    High cpu_time_pct means workers are already consuming most CPU time.
+    High nvcsw_freq usually means workers frequently yield on mutex/cond waits
+    or short sleeps, so extra concurrency would mostly add scheduler churn.
+    High nivcsw_freq usually means the OS is preempting runnable workers under
+    CPU pressure, so adding more runnable threads would increase contention.
+  */
+  if (cpu_time_pct <= 0) {
+    /*
+      Integer sampling can round a very low CPU load down to 0. Treat that as a
+      no-pressure window and avoid dividing by zero when estimating the quota.
+    */
+    m_active_threads_quota.store(tp_max_threads_quota(), RELAX_ORDER);
+    return;
+  }
+
+  const int min_active_threads_quota = tp_min_threads_quota();
+  const int max_active_threads_quota = tp_max_threads_quota();
+  if (cpu_time_pct > cpu_usage_threshold ||
+      nvcsw_freq > threadpool_nvcsw_freq_threshold ||
+      nivcsw_freq > threadpool_nivcsw_freq_threshold) {
+    const int quota_delta = std::max(
+        1, static_cast<int>(threadpool_size * thread_quota_scale_factor()));
+
+    /* Quickly reduce the quota when there are too many active threads. */
+    if (active_threads_quota >= (max_active_threads_quota / 2)) {
+      active_threads_quota = min_active_threads_quota + quota_delta;
+      if (active_threads_quota > max_active_threads_quota) {
+        active_threads_quota = max_active_threads_quota;
+      }
+    } else {
+      active_threads_quota -= quota_delta;
+      if (active_threads_quota < min_active_threads_quota) {
+        active_threads_quota = min_active_threads_quota;
+      }
+    }
+
+    m_active_threads_quota.store(active_threads_quota, RELAX_ORDER);
+  } else {
+    const int evaluate_quota =
+        tp_global_active_threads_counter.load(RELAX_ORDER) * 100 / cpu_time_pct;
+
+    if (active_threads_quota < evaluate_quota) {
+      active_threads_quota = evaluate_quota;
+    } else {
+      active_threads_quota +=
+        static_cast<int>(threadpool_size * thread_quota_scale_factor());
+    }
+
+    if (active_threads_quota > max_active_threads_quota) {
+      active_threads_quota = max_active_threads_quota;
+    }
+
+    m_active_threads_quota.store(active_threads_quota, RELAX_ORDER);
+  }
+}
