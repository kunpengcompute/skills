diff --git a/sql/rpl_commit_stage_manager.h b/sql/rpl_commit_stage_manager.h
index c5830c2de..ec8aae0ff 100644
--- a/sql/rpl_commit_stage_manager.h
+++ b/sql/rpl_commit_stage_manager.h
@@ -35,6 +35,10 @@
 
 class THD;
 
+#if defined(__aarch64__) && defined(__linux__)
+const static size_t N_LOCKS_PER_COMMIT_QUEUE = 32;
+#endif
+
 /**
   Class for maintaining the commit stages for binary log group commit.
  */
@@ -44,9 +48,21 @@ class Commit_stage_manager {
     friend class Commit_stage_manager;
 
    public:
-    Mutex_queue() : m_first(nullptr), m_last(&m_first), m_size(0) {}
-
-    void init(mysql_mutex_t *lock) { m_lock = lock; }
+    Mutex_queue() : m_first(nullptr), m_last(&m_first), m_size(0)
+#if defined(__aarch64__) && defined(__linux__)
+                  , m_to_assign_lock(-1)
+#endif
+                  {}
+
+    void init(mysql_mutex_t *lock) {
+      m_lock = lock;
+#if defined(__aarch64__) && defined(__linux__)
+      for (size_t i = 0; i < N_LOCKS_PER_COMMIT_QUEUE; i++) {
+        mysql_mutex_init(PSI_NOT_INSTRUMENTED, &m_pending_locks[i], MY_MUTEX_INIT_FAST);
+        mysql_cond_init(PSI_NOT_INSTRUMENTED, &m_pending_conds[i]);
+      }
+#endif
+    }
 
     bool is_empty() const { return m_first == nullptr; }
 
@@ -109,6 +125,31 @@ class Commit_stage_manager {
 
     void unlock() { mysql_mutex_unlock(m_lock); }
 
+#if defined(__aarch64__) && defined(__linux__)
+    void assign_pending_lock(bool is_header, THD *first) {
+      Transaction_ctx *tx = first->get_transaction();
+      assert(tx->m_pending_commit_lock == nullptr);
+      assert(tx->m_pending_commit_cond == nullptr);
+      if (is_header) {
+        /* leader will reserve lock for followers. */
+        m_to_assign_lock++;
+        assert(m_to_assign_lock >= 0);
+        assert(m_to_assign_lock <= static_cast<int>(N_LOCKS_PER_COMMIT_QUEUE));
+        m_to_assign_lock = (m_to_assign_lock) % N_LOCKS_PER_COMMIT_QUEUE;
+      } else {
+        tx->m_pending_commit_lock = &m_pending_locks[m_to_assign_lock];
+        tx->m_pending_commit_cond = &m_pending_conds[m_to_assign_lock];
+      }
+    }
+
+    void deinit() {
+      for (size_t i = 0; i < N_LOCKS_PER_COMMIT_QUEUE; i++) {
+        mysql_mutex_destroy(&m_pending_locks[i]);
+        mysql_cond_destroy(&m_pending_conds[i]);
+      }
+    }
+#endif
+
     void assert_owner() { mysql_mutex_assert_owner(m_lock); }
 
    private:
@@ -139,6 +180,14 @@ class Commit_stage_manager {
     /** Lock for protecting the queue. */
     mysql_mutex_t *m_lock;
 
+#if defined(__aarch64__) && defined(__linux__)
+    int m_to_assign_lock;
+
+    mysql_mutex_t m_pending_locks[N_LOCKS_PER_COMMIT_QUEUE];
+
+    mysql_cond_t m_pending_conds[N_LOCKS_PER_COMMIT_QUEUE];
+#endif
+
     /*
       This attribute did not have the desired effect, at least not according
       to -fsanitize=undefined with gcc 5.2.1
@@ -447,11 +496,13 @@ class Commit_stage_manager {
   */
   mysql_cond_t m_stage_cond_leader;
 
+#if !defined(__aarch64__) || !defined(__linux__)
   /**
      Condition variable to indicate that the binlog threads can wake up
      and continue.
   */
   mysql_cond_t m_stage_cond_binlog;
+#endif
 
   /**
      Condition variable to indicate that the flush to storage engine
@@ -459,8 +510,10 @@ class Commit_stage_manager {
   */
   mysql_cond_t m_stage_cond_commit_order;
 
+#if !defined(__aarch64__) || !defined(__linux__) || !defined(NDEBUG)
   /** Mutex used for the condition variable above */
   mysql_mutex_t m_lock_done;
+#endif
 
   /** Mutex used for the stage level locks */
   mysql_mutex_t m_queue_lock[STAGE_COUNTER - 1];
