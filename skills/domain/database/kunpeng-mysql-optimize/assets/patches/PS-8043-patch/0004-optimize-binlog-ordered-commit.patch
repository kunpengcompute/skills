   }
 }
 
+#if defined(__aarch64__) && defined(__linux__)
+void Commit_stage_manager::signal_done(THD *queue, StageID stage) {
+  std::set<mysql_cond_t *> conds;
+  std::set<mysql_cond_t *>::iterator it;
+  mysql_mutex_t *current_lock = nullptr;
+
+  /* Note: The leader in this queue is not assgined lock. */
+  assert(queue->get_transaction()->m_pending_commit_lock == current_lock);
+
+  for (THD *thd = queue; thd; thd = thd->next_to_commit) {
+    if (current_lock != thd->get_transaction()->m_pending_commit_lock) {
+      if (current_lock != nullptr) {
+        mysql_mutex_unlock(current_lock);
+      }
+      current_lock = thd->get_transaction()->m_pending_commit_lock;
+
+      if (stage != COMMIT_ORDER_FLUSH_STAGE) {
+        assert(thd->get_transaction()->m_pending_commit_cond != nullptr);
+        conds.insert(thd->get_transaction()->m_pending_commit_cond);
+      }
+
+      /* only leader has no lock and condition wait. */
+      assert(current_lock != nullptr);
+      mysql_mutex_lock(current_lock);
+    }
+    thd->tx_commit_pending = false;
+    thd->rpl_thd_ctx.binlog_group_commit_ctx().reset();
+  }
+
+  if (current_lock != nullptr) {
+    mysql_mutex_unlock(current_lock);
+  }
+
+  if (stage == COMMIT_ORDER_FLUSH_STAGE) {
+    mysql_cond_broadcast(&m_stage_cond_commit_order);
+  }
+
+  /* Every queue in order commit will share the same lock. */
+  assert(conds.size() <= STAGE_COUNTER);
+  for (it = conds.begin(); it != conds.end(); it++) {
+    mysql_cond_broadcast(*it);
+  }
+}
+#else
 void Commit_stage_manager::signal_done(THD *queue, StageID stage) {
   mysql_mutex_lock(&m_lock_done);
 
@@ -504,6 +604,7 @@ void Commit_stage_manager::signal_done(THD *queue, StageID stage) {
 
   mysql_mutex_unlock(&m_lock_done);
 }
+#endif
 
