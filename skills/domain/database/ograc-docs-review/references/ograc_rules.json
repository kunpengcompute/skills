{
  "version": "1.0",
  "priority_rules": [
    {
      "level": "P0",
      "type": "错别字/拼写导致误导",
      "example": "`NOLOGING`→`NOLOGGING`，`不适用`→`不使用`"
    },
    {
      "level": "P0",
      "type": "文件名/TOC 错误",
      "example": "`artitioned_`→`partitioned_`"
    },
    {
      "level": "P0",
      "type": "英文专有名词未用行内代码",
      "example": "`JDBC`、`DBStor`、`ODBC`、`SQL`、命令/路径等应包在 `` ` `` 中"
    },
    {
      "level": "P0",
      "type": "弯引号/Unicode 引号",
      "example": "JDBC URL、参数、代码中的弯引号应改为 ASCII 直引号"
    },
    {
      "level": "P0",
      "type": "中英文混排缺空格",
      "example": "`oGRAC提供了`→`oGRAC 提供了`"
    },
    {
      "level": "P1",
      "type": "命名 copy-paste 残留",
      "example": "`openGaussSpace`→`ogracSpace`，`ograc提供`→`oGRAC 提供`"
    },
    {
      "level": "P1",
      "type": "语义/技术描述错误",
      "example": "`书签页`→`书签列`，`共享内存服务`→`分布式内存服务（DMS）`"
    },
    {
      "level": "P1",
      "type": "上下文矛盾",
      "example": "删除 DBStor 后，其他文档中相关描述应同步删除"
    },
    {
      "level": "P2",
      "type": "语法与口语化",
      "example": "「当你不需要」→「适用于无需…的场景」，「也就是说」→「即/因此」"
    },
    {
      "level": "P2",
      "type": "Markdown 规范",
      "example": "` ```SQL `→` ```sql `，补全断裂链接"
    },
    {
      "level": "P2",
      "type": "标点一致性",
      "example": "同一段落中英文分号 `;` 与中文句号 `。` 不混用"
    },
    {
      "level": "P2",
      "type": "Shell 代码块可一键复制",
      "example": "删除行首 `$` / `#` 提示符，用注释说明命令用途"
    },
    {
      "level": "P3",
      "type": "HTML 残留清理",
      "example": "`zh-cn_topic_*` 锚点、`<table>` 转 Markdown"
    },
    {
      "level": "P3",
      "type": "缺失图片",
      "example": "补充资源或修正路径"
    }
  ],
  "naming_conventions": [
    {
      "scenario": "产品名（正文）",
      "rule": "`oGRAC`（首字母小写 o，其余大写）"
    },
    {
      "scenario": "示例表空间",
      "rule": "`ogracSpace` / SQL 中大写 `OGRACSPACE`"
    },
    {
      "scenario": "SQL 提示符",
      "rule": "`SQL>` 或 `oGRAC>`，不用 `openGauss=#`"
    },
    {
      "scenario": "JDBC 负载均衡文档标题",
      "rule": "`JDBC 多节点负载均衡`（非「主备集群」）"
    },
    {
      "scenario": "堆管理标题",
      "rule": "`# 堆管理`（非 `Heap Management`）"
    },
    {
      "scenario": "仓库 URL",
      "rule": "统一为 `https://gitcode.com/opengauss/oGRAC.git`（小写 `opengauss`）"
    },
    {
      "scenario": "产品名变体",
      "rule": "禁止 `ogRac`、`OGRAC`、`openGauss` 等变体指代 oGRAC 产品"
    }
  ],
  "spacing_rules": {
    "description": "中文正文与英文单词、数字、版本号之间应加空格；但英文与相邻的英文标点、数字单位、代码符号之间不加空格。例外：URL、文件路径、命令行参数组、连字符复合词内部不加空格，例如 `openGauss-third_party_binarylibs`、`SQL_STAGE_THRESHOLD`。",
    "examples": [
      {
        "scenario": "产品名 + 中文",
        "example": "`oGRAC 提供了`、`oGRAC 中支持`"
      },
      {
        "scenario": "英文术语 + 中文",
        "example": "`JDBC 驱动`、`SQL 语句`、`CPU 核心数`"
      },
      {
        "scenario": "数字 + 中文单位",
        "example": "`64 位时间戳`、`2 个 ITL 条目`"
      },
      {
        "scenario": "版本号",
        "example": "`JDBC 4.0 接口`"
      },
      {
        "scenario": "代码符号紧邻英文",
        "example": "`oGRAC(openGauss...)` 括号内不变、`SQL>` 提示符不变"
      }
    ]
  },
  "inline_code_terms": {
    "category_labels": {
      "protocols_interfaces": "协议/接口",
      "commands_tools": "命令/工具",
      "paths_files": "路径/文件",
      "parameters_options": "参数/选项",
      "code_keywords_functions": "代码片段中的关键字、函数名"
    },
    "terms": {
      "protocols_interfaces": [
        "JDBC",
        "ODBC",
        "SQL",
        "DBStor",
        "WSR"
      ],
      "commands_tools": [
        "gsql",
        "ogsql",
        "git",
        "make",
        "cmake"
      ],
      "paths_files": [
        "/usr/local/etc",
        "/opt/ograc",
        "ogjdbc.jar",
        "_toc.yaml",
        ".gitignore"
      ],
      "parameters_options": [
        "host",
        "port",
        "database",
        "M_RUNING_MODE"
      ],
      "code_keywords_functions": [
        "INSERT",
        "SELECT",
        "pg_xlog"
      ]
    },
    "notes": [
      "不要用全角弯引号替代 `` ` ``。",
      "同一文档中同一术语的包裹方式保持一致。"
    ]
  },
