  "sql_keywords": [
    {
      "lowercase": "create table",
      "uppercase": "CREATE TABLE"
    },
    {
      "lowercase": "select * from",
      "uppercase": "SELECT * FROM"
    },
    {
      "lowercase": "insert into",
      "uppercase": "INSERT INTO"
    },
    {
      "lowercase": "alter system set",
      "uppercase": "ALTER SYSTEM SET"
    },
    {
      "lowercase": "group by",
      "uppercase": "GROUP BY"
    }
  ],
  "code_block_languages": {
    "description": "代码块应尽量带语言标签，避免无标签的裸围栏。",
    "allowed": {
      "sql": [
        "sql"
      ],
      "shell": [
        "shell",
        "bash"
      ],
      "text": [
        "text"
      ],
      "java": [
        "java"
      ],
      "c": [
        "c"
      ],
      "bnf": [
        "bnf"
      ]
    },
    "forbidden": [
      "SQL",
      "Sql",
      "BNF",
      "Bnf"
    ]
  },
  "search_patterns": [
    {
      "name": "产品名变体",
      "description": "检查 oGRAC 产品名的错误大小写/变体。",
      "command": "rg -n \"(?i)(?<![\\w/])\\b(ogRac|OGRAC)(?!\\w)\" docs/zh"
    },
    {
      "name": "错别字/拼写",
      "description": "批量检索常见错别字与拼写错误。",
      "command": "rg -n \"NOLOGING|proprity|COLUME|COLUMAN|Defination|同名词|统计试图|DETAFILE|PARITION|golbal|OERRDERED|artitioned_tables|UNLINITED|UPADATE|EXLUDING|RLUE|truancate|snopshot|评诂|边长|微妙|数字字典|DETETE|DRIOP| unto \" docs/zh"
    },
    {
      "name": "命名残留",
      "description": "检查 openGauss/oGRAC 命名 copy-paste 残留。",
      "command": "rg -n \"openGaussSpace|OPENGAUSSSPACE|ograc提供|ogracDB|OpenGauss oGRAC|共享内存服务|ODBC在研|jdbc主备\" docs/zh"
    },
    {
      "name": "Markdown 代码块标签",
      "description": "检查代码块语言标签大小写或无标签。",
      "command": "rg -n '^```[A-Z]{2,}$|^```\\s*$|```SQL|```Sql|```BNF|```Bnf' docs/zh"
    },
    {
      "name": "弯引号/Unicode 引号",
      "description": "检查代码/参数中是否出现 Unicode 弯引号。",
      "command": "rg -n '[“”‘’]' docs/zh"
    },
    {
      "name": "英文专有名词未包裹",
      "description": "按常用词抽查英文专有名词是否未用行内代码包裹。",
      "command": "rg -n '(?<!`)\\b(JDBC|ODBC|DBStor|WSR|SQL|gsql|ogsql|SGA|PGA|DMS|DSS|CMS|DRC|DLS|DCS|MVCC|ITL|SCN|TXN|XID|Redo|Undo|CKPT|CBO|API|LOB)\\b(?!`)' docs/zh"
    },
    {
      "name": "中英文混排缺空格",
      "description": "中文后紧跟 2 个以上字母/数字，或字母/数字后紧跟中文。",
      "command": "rg -n '[\\x{4e00}-\\x{9fff}][a-zA-Z0-9]{2,}[\\x{4e00}-\\x{9fff}]|[\\x{4e00}-\\x{9fff}][0-9]+[\\x{4e00}-\\x{9fff}]' docs/zh"
    },
    {
      "name": "SQL 关键字小写",
      "description": "仅在 SQL> 提示符后检查 SQL 关键字是否小写。",
      "command": "rg -n '^\\s*SQL>\\s+(create|select|insert|update|delete|drop|alter|grant|revoke|commit|rollback|begin|end|declare|set|show|analyze|explain|truncate|merge|replace)\\s+' docs/zh"
    },
    {
      "name": "有序列表使用中文顿号",
      "description": "检查有序列表是否误用中文顿号。",
      "command": "rg -n '^\\s*\\d+\\s*、\\s' docs/zh"
    },
    {
      "name": "HTML 残留规模",
      "description": "检查 HTML 残留文件范围。",
      "command": "rg -l \"zh-cn_topic|cellrowborder\" docs/zh"
    },
    {
      "name": "行尾空格",
      "description": "检查行尾多余空格。",
      "command": "rg -n '\\s+$' docs/zh"
    },
    {
      "name": "连续空行",
      "description": "检查连续空行。",
      "command": "rg -n '^\\s*$' -A 1 '^\\s*$' docs/zh"
    }
  ],
  "manual_checks": [
    {
      "name": "TOC 一致性",
      "description": "检查 `_toc.yaml` 中的 `href` 路径与 `docs/zh` 下实际文件名一致。"
    },
    {
      "name": "Shell 代码块可一键复制",
      "description": "抽查 ```shell / ```bash 代码块，确认行首无 `$` / `#` 提示符。"
    }
  ]
}
